{% comment %}
  ka-glossary-terms.liquid — Glossary grid from metaobjects (meta-driven)
  Usage: {% render 'ka-glossary-terms', article: article, blog: blog %}
{% endcomment %}

{%- liquid
  assign glossary = article.metafields.custom.glossary_terms.value
  assign glossary_eyebrow = article.metafields.custom.glossary_eyebrow | default: blog.metafields.custom.glossary_eyebrow
  assign glossary_heading = article.metafields.custom.glossary_heading | default: blog.metafields.custom.glossary_heading
-%}

{%- if glossary != blank and glossary.size > 0 -%}
  <section class="ka-article-glossary-card ka-glossary-section ka-section-spaced" id="glossary">
    {%- if glossary_eyebrow != blank -%}
      <p class="ka-blog-eyebrow">{{ glossary_eyebrow }}</p>
    {%- endif -%}
    {%- if glossary_heading != blank -%}
      <h2>{{ glossary_heading }}</h2>
    {%- endif -%}
    <div class="ka-article-glossary-grid">
      {%- for term in glossary -%}
        <div>
          <b>{{ term.term }}</b>
          {%- if term.secondary_term != blank -%}
            <span class="ka-blog-muted ka-glossary-secondary">({{ term.secondary_term }})</span>
          {%- endif -%}
          {%- if term.pronunciation != blank -%}
            <span class="ka-blog-muted ka-glossary-pronunciation">{{ term.pronunciation }}</span>
          {%- endif -%}
          {%- if term.short_definition != blank -%}
            <p class="ka-blog-muted">{{ term.short_definition }}</p>
          {%- endif -%}
        </div>
      {%- endfor -%}
    </div>
  </section>
{%- endif -%}

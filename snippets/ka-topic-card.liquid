{% comment %}
  ka-topic-card.liquid — Full-image topic card with dark fallback image list
  Usage: {% render 'ka-topic-card', topic: topic, blog: blog, index: index %}
  topic = blog_topic metaobject entry
{% endcomment %}

{%- liquid
  assign topic_title = topic.title.value | default: topic.title | default: topic
  assign topic_image = topic.image.value | default: topic.image
  assign topic_tag = topic.article_filter_tag.value | default: topic.article_filter_tag | default: topic_title | handleize
  assign topic_count_label = topic.cta_label.value | default: topic.cta_label | default: 'Explore topic'

  # Generate Unsplash fallback dark images
  assign default_img_index = index | default: 0 | modulo: 18
  case default_img_index
    when 0
      assign fallback_img = 'https://images.unsplash.com/photo-1512290923902-8a9f81dc236c?auto=format&fit=crop&q=80&w=600'
    when 1
      assign fallback_img = 'https://images.unsplash.com/photo-1515003197210-e0cd71810b5f?auto=format&fit=crop&q=80&w=600'
    when 2
      assign fallback_img = 'https://images.unsplash.com/photo-1544816155-12df9643f363?auto=format&fit=crop&q=80&w=600'
    when 3
      assign fallback_img = 'https://images.unsplash.com/photo-1515694346937-94d85e41e6f0?auto=format&fit=crop&q=80&w=600'
    when 4
      assign fallback_img = 'https://images.unsplash.com/photo-1502741224143-90386d7c8c82?auto=format&fit=crop&q=80&w=600'
    when 5
      assign fallback_img = 'https://images.unsplash.com/photo-1535254973040-607b474cb50d?auto=format&fit=crop&q=80&w=600'
    when 6
      assign fallback_img = 'https://images.unsplash.com/photo-1517849845537-4d257902454a?auto=format&fit=crop&q=80&w=600'
    when 7
      assign fallback_img = 'https://images.unsplash.com/photo-1556911220-e15b29be8c8f?auto=format&fit=crop&q=80&w=600'
    when 8
      assign fallback_img = 'https://images.unsplash.com/photo-1563483783225-bc245ff8f0f0?auto=format&fit=crop&q=80&w=600'
    when 9
      assign fallback_img = 'https://images.unsplash.com/photo-1505253716362-afaea1d3d1af?auto=format&fit=crop&q=80&w=600'
    when 10
      assign fallback_img = 'https://images.unsplash.com/photo-1471193945509-9ad0617afabf?auto=format&fit=crop&q=80&w=600'
    when 11
      assign fallback_img = 'https://images.unsplash.com/photo-1514733670139-4d87a1941d55?auto=format&fit=crop&q=80&w=600'
    when 12
      assign fallback_img = 'https://images.unsplash.com/photo-1498837167922-ddd27525d352?auto=format&fit=crop&q=80&w=600'
    when 13
      assign fallback_img = 'https://images.unsplash.com/photo-1509440159596-0249088772ff?auto=format&fit=crop&q=80&w=600'
    when 14
      assign fallback_img = 'https://images.unsplash.com/photo-1541256996761-85df2efaa164?auto=format&fit=crop&q=80&w=600'
    when 15
      assign fallback_img = 'https://images.unsplash.com/photo-1505576399279-565b52d4ac71?auto=format&fit=crop&q=80&w=600'
    when 16
      assign fallback_img = 'https://images.unsplash.com/photo-1512290923902-8a9f81dc236c?auto=format&fit=crop&q=80&w=600'
    when 17
      assign fallback_img = 'https://images.unsplash.com/photo-1550592754-07e0e7a2b97f?auto=format&fit=crop&q=80&w=600'
  endcase
-%}

<a class="ka-blog-image-card" href="{{ blog.url }}/tagged/{{ topic_tag }}">
  {%- if topic_image != blank -%}
    {%- assign topic_img_url = topic_image | image_url: width: 600 -%}
    {%- unless topic_img_url contains 'http' -%}
      {%- assign topic_img_url = 'https://cdn.shopify.com' | append: topic_img_url -%}
    {%- endunless -%}
    <div class="ka-blog-image-card__bg" style="background-image: url('{{ topic_img_url }}');"></div>
  {%- else -%}
    <div class="ka-blog-image-card__bg" style="background-image: url('{{ fallback_img }}');"></div>
  {%- endif -%}
  <div class="ka-blog-image-card__overlay" aria-hidden="true"></div>
  <div class="ka-blog-image-card__content">
    <h3>{{ topic_title }}</h3>
    <span class="ka-blog-read-more">{{ topic_count_label }}</span>
  </div>
</a>

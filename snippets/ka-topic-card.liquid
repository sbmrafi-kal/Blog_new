{% comment %}
  ka-topic-card.liquid — Full-image topic card (meta-driven)
  Usage: {% render 'ka-topic-card', topic: topic, blog: blog, index: index %}
  topic = blog_topic metaobject entry
{% endcomment %}

{%- liquid
  assign topic_title = topic.title.value | default: topic.title | default: topic
  assign topic_image = topic.image.value
  assign topic_tag = topic.article_filter_tag.value | default: topic.article_filter_tag
  assign topic_handle = topic.system.handle | default: topic.handle | default: topic_tag | handleize
  assign topic_count_label = topic.cta_label.value | default: topic.cta_label
  assign topic_img_url = ''

  if topic_image != blank
    assign topic_img_url = topic_image | image_url: width: 600
  endif
-%}

{%- if topic_title != blank -%}
  <a class="ka-blog-image-card" href="{{ blog.url }}/tagged/{{ topic_tag | handleize }}?topic={{ topic_handle }}">
    {%- if topic_img_url != blank -%}
      <img class="ka-blog-image-card__bg" src="{{ topic_img_url }}" alt="{{ topic_title | escape }}" loading="lazy" width="600" height="400">
    {%- endif -%}
    <div class="ka-blog-image-card__overlay" aria-hidden="true"></div>
    <div class="ka-blog-image-card__content">
      <h3>{{ topic_title }}</h3>
      {%- if topic_count_label != blank -%}
        <span class="ka-blog-read-more">{{ topic_count_label }}</span>
      {%- endif -%}
    </div>
  </a>
{%- endif -%}

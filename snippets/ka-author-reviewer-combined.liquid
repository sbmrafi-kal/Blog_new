{%- liquid
  assign author_name_display = author_profile.name
  assign author_qual = author_profile.qualifications | default: author_profile.degree
  assign author_name = author_name_display
  if author_qual != blank
    assign author_name = author_name | append: ' ' | append: author_qual
  endif
  assign author_role = 'WRITTEN BY'
  assign author_bio = author_profile.short_bio
  assign author_photo = author_profile.photo
  
  assign reviewer_name_display = reviewer_profile.name
  assign reviewer_qual = reviewer_profile.qualifications | default: reviewer_profile.degree
  assign reviewer_name = reviewer_name_display
  if reviewer_qual != blank
    assign reviewer_name = reviewer_name | append: ' ' | append: reviewer_qual
  endif
  assign reviewer_role = 'REVIEWED BY'
  assign reviewer_bio = reviewer_profile.short_bio
  assign reviewer_photo = reviewer_profile.photo
-%}

<div class="ka-article-author-reviewer-card" id="author-reviewer-card">
  
  {%- comment -%} Written by Card {%- endcomment -%}
  {%- if author_name_display != blank -%}
    <div class="ka-article-card-state ka-article-card-state--author">
      <div class="ka-article-author-card">
        <p class="ka-blog-eyebrow">{{ author_role }}</p>
        <div class="ka-article-author-bio-row">
          {%- if author_photo != blank -%}
            <div class="ka-article-avatar" aria-hidden="true">
              <img
                src="{{ author_photo | image_url: width: 176 }}"
                alt="{{ author_name | escape }}"
                loading="lazy"
                width="88"
                height="88"
              >
              <span class="ka-avatar-hover-overlay">Read bio &rarr;</span>
            </div>
          {%- endif -%}
          <div class="ka-article-author-content">
            <h2>{{ author_name_display }} {%- if author_qual != blank -%}<span class="ka-author-qual">({{ author_qual }})</span>{%- endif -%}</h2>
            {%- if author_bio != blank -%}
              <p class="ka-article-author-bio">{{ author_bio }}</p>
            {%- endif -%}
          </div>
        </div>
      </div>
    </div>
  {%- endif -%}

  {%- comment -%} Reviewed by Card {%- endcomment -%}
  {%- if reviewer_name_display != blank -%}
    <div class="ka-article-card-state ka-article-card-state--reviewer">
      <div class="ka-article-author-card">
        <p class="ka-blog-eyebrow">{{ reviewer_role }}</p>
        <div class="ka-article-author-bio-row">
          {%- if reviewer_photo != blank -%}
            <div class="ka-article-avatar" aria-hidden="true">
              <img
                src="{{ reviewer_photo | image_url: width: 176 }}"
                alt="{{ reviewer_name | escape }}"
                loading="lazy"
                width="88"
                height="88"
              >
              <span class="ka-avatar-hover-overlay">Read bio &rarr;</span>
            </div>
          {%- endif -%}
          <div class="ka-article-author-content">
            <h2>{{ reviewer_name_display }} {%- if reviewer_qual != blank -%}<span class="ka-author-qual">({{ reviewer_qual }})</span>{%- endif -%}</h2>
            {%- if reviewer_bio != blank -%}
              <p class="ka-article-author-bio">{{ reviewer_bio }}</p>
            {%- endif -%}
          </div>
        </div>
      </div>
    </div>
  {%- endif -%}

</div>

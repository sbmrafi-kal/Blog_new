{% comment %}
  ka-care-path-card.liquid — Care path row card (meta-driven)
  Usage: {% render 'ka-care-path-card', care_path: care_path, blog: blog %}
{% endcomment %}

{%- liquid
  assign path_title = care_path.title.value | default: care_path.title | default: title
  assign path_subtitle = care_path.subtitle.value | default: care_path.subtitle | default: subtitle
  assign path_cta = care_path.cta_text.value | default: care_path.cta_text | default: 'Learn More'
  assign path_url = care_path.link_url.value | default: care_path.link_url | default: care_path.url.value | default: care_path.url

  if path_url == blank and care_path.linked_topic != blank
    assign topic_obj = care_path.linked_topic.value | default: care_path.linked_topic
    assign topic_tag = topic_obj.article_filter_tag.value | default: topic_obj.article_filter_tag | handleize
    assign topic_handle = topic_obj.system.handle | default: topic_obj.handle | handleize
    assign path_url = blog.url | append: '/tagged/' | append: topic_tag | append: '?care_path=' | append: topic_handle
  endif
-%}

{%- if path_title != blank -%}
  <a class="ka-blog-path-row" href="{{ path_url | default: '#' }}">
    <div>
      <h3>{{ path_title }}</h3>
      {%- if path_subtitle != blank -%}
        <p class="ka-blog-muted">{{ path_subtitle }}</p>
      {%- endif -%}
    </div>
    <div class="ka-blog-path-tags">
      <span class="ka-blog-path-cta">{{ path_cta }} →</span>
    </div>
  </a>
{%- endif -%}

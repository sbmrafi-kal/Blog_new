{% comment %}
  ka-care-path-card.liquid — Care path row card
  Usage: {% render 'ka-care-path-card', care_path: care_path, blog: blog %}
  care_path = care_path metaobject entry OR block settings
{% endcomment %}

{%- liquid
  assign path_title = care_path.title | default: title
  assign path_subtitle = care_path.subtitle | default: subtitle
  assign path_cta = 'Learn More'
  assign path_url = care_path.link_url

  if path_url == blank and care_path.linked_topic
    assign raw_tag = care_path.linked_topic.article_filter_tag.value | default: care_path.linked_topic.article_filter_tag | default: path_title
    assign raw_tag_handle = raw_tag | handleize
    if raw_tag_handle contains 'digestion' or raw_tag_handle contains 'digest' or raw_tag_handle contains 'gut'
      assign topic_tag = 'digestion'
    elsif raw_tag_handle contains 'sleep' or raw_tag_handle contains 'stress' or raw_tag_handle contains 'mind'
      assign topic_tag = 'sleep'
    elsif raw_tag_handle contains 'joints' or raw_tag_handle contains 'pain' or raw_tag_handle contains 'bone'
      assign topic_tag = 'pain-joints'
    elsif raw_tag_handle contains 'skin' or raw_tag_handle contains 'hair' or raw_tag_handle contains 'beauty'
      assign topic_tag = 'skin-hair'
    elsif raw_tag_handle contains 'women'
      assign topic_tag = 'women-s-health'
    elsif raw_tag_handle contains 'men'
      assign topic_tag = 'men-s-health'
    elsif raw_tag_handle contains 'kids' or raw_tag_handle contains 'children'
      assign topic_tag = 'kids'
    elsif raw_tag_handle contains 'elder' or raw_tag_handle contains 'old'
      assign topic_tag = 'elders'
    elsif raw_tag_handle contains 'herb'
      assign topic_tag = 'herbs'
    elsif raw_tag_handle contains 'weight'
      assign topic_tag = 'weight'
    elsif raw_tag_handle contains 'immunity'
      assign topic_tag = 'immunity'
    elsif raw_tag_handle contains 'detox'
      assign topic_tag = 'detox'
    else
      assign topic_tag = raw_tag_handle
    endif
    assign care_path_handle = care_path.system.handle | default: care_path.handle | default: path_title | handleize
    assign path_url = blog.url | append: '/tagged/' | append: topic_tag | append: '?care_path=' | append: care_path_handle
  endif

  if path_url == blank
    assign raw_tag_handle = path_title | handleize
    if raw_tag_handle contains 'digestion' or raw_tag_handle contains 'digest' or raw_tag_handle contains 'gut'
      assign topic_tag = 'digestion'
    elsif raw_tag_handle contains 'sleep' or raw_tag_handle contains 'stress' or raw_tag_handle contains 'mind'
      assign topic_tag = 'sleep'
    elsif raw_tag_handle contains 'joints' or raw_tag_handle contains 'pain' or raw_tag_handle contains 'bone'
      assign topic_tag = 'pain-joints'
    elsif raw_tag_handle contains 'skin' or raw_tag_handle contains 'hair' or raw_tag_handle contains 'beauty'
      assign topic_tag = 'skin-hair'
    elsif raw_tag_handle contains 'women'
      assign topic_tag = 'women-s-health'
    elsif raw_tag_handle contains 'men'
      assign topic_tag = 'men-s-health'
    elsif raw_tag_handle contains 'kids' or raw_tag_handle contains 'children'
      assign topic_tag = 'kids'
    elsif raw_tag_handle contains 'elder' or raw_tag_handle contains 'old'
      assign topic_tag = 'elders'
    elsif raw_tag_handle contains 'herb'
      assign topic_tag = 'herbs'
    elsif raw_tag_handle contains 'weight'
      assign topic_tag = 'weight'
    elsif raw_tag_handle contains 'immunity'
      assign topic_tag = 'immunity'
    elsif raw_tag_handle contains 'detox'
      assign topic_tag = 'detox'
    else
      assign topic_tag = raw_tag_handle
    endif
    assign path_url = blog.url | append: '/tagged/' | append: topic_tag
  endif
-%}

<a class="ka-blog-path-row" href="{{ path_url }}">
  <div>
    <h3>{{ path_title }}</h3>
    {%- if path_subtitle != blank -%}
      <p class="ka-blog-muted">{{ path_subtitle }}</p>
    {%- endif -%}
  </div>
  <div class="ka-blog-path-tags">
    <span class="ka-blog-path-cta">{{ path_cta }} →</span>
  </div>
</a>

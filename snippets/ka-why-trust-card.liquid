{% comment %}
  ka-why-trust-card.liquid — Collapsible trust card (meta-driven)
  Usage: {% render 'ka-why-trust-card', article: article %}
{% endcomment %}

{%- liquid
  assign trust_metaobject = article.metafields.custom.why_trust_kerala_ayurveda.value
-%}

{%- if trust_metaobject != blank -%}
  <div class="ka-why-trust-card" id="ka-why-trust-card">
    <button class="ka-why-trust-header" type="button" aria-expanded="false" aria-controls="ka-why-trust-content">
      <div class="ka-why-trust-header-left">
        <div class="ka-why-trust-logo-placeholder">
          <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="#1E4B3C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ka-why-trust-icon">
            <path d="M12 22C17.5228 22 22 17.5228 22 12C22 6.47715 17.5228 2 12 2C6.47715 2 2 6.47715 2 12C2 17.5228 6.47715 22 12 22Z"></path>
            <path d="M12 6C12 6 8.5 9.5 8.5 12C8.5 14.5 10.5 16 12 16C13.5 16 15.5 14.5 15.5 12C15.5 9.5 12 6 12 6Z"></path>
          </svg>
        </div>
        {%- if trust_metaobject.title != blank -%}
          <span class="ka-why-trust-title">{{ trust_metaobject.title }}</span>
        {%- endif -%}
      </div>
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="#1E4B3C" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ka-why-trust-chevron">
        <polyline points="6 9 12 15 18 9"></polyline>
      </svg>
    </button>
    <div class="ka-why-trust-content ka-collapsible-content" id="ka-why-trust-content">
      <div class="ka-why-trust-inner">
        {%- if trust_metaobject.content_html != blank -%}
          <div class="rte">
            {{ trust_metaobject.content_html }}
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>
{%- endif -%}
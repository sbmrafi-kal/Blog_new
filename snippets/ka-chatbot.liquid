{% comment %}
  ka-chatbot.liquid — Ask Guruji chatbot popup widget (meta-driven)
  Usage: {% render 'ka-chatbot', blog: blog %}
{% endcomment %}

{%- liquid
  assign chatbot_name = blog.metafields.custom.chatbot_name
  assign chatbot_subtitle = blog.metafields.custom.chatbot_subtitle
  assign chatbot_placeholder = blog.metafields.custom.chatbot_placeholder
  assign chatbot_options = blog.metafields.custom.chatbot_quick_options.value
-%}

{%- if chatbot_name != blank -%}
  <div class="ka-chatbot-container">
    <button class="ka-blog-floating-cta ka-chatbot-trigger" id="ka-chatbot-trigger" aria-label="{{ chatbot_name }}">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="ka-chatbot-trigger-icon">
        <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"></path>
      </svg>
      <span class="ka-chatbot-label">{{ chatbot_name }}</span>
    </button>

    <div class="ka-chatbot-window ka-chatbot-hidden" id="ka-chatbot-window" aria-hidden="true">
      <div class="ka-chatbot-header">
        <div class="ka-chatbot-header-info">
          <div class="ka-chatbot-avatar-small">{{ chatbot_name | slice: 0 }}</div>
          <div>
            <h3>{{ chatbot_name }}</h3>
            {%- if chatbot_subtitle != blank -%}
              <p>{{ chatbot_subtitle }}</p>
            {%- endif -%}
          </div>
        </div>
      </div>
      <div class="ka-chatbot-messages" id="ka-chatbot-messages">
        {%- if chatbot_options != blank and chatbot_options.size > 0 -%}
          <div class="ka-chatbot-quick-options">
            {%- for option in chatbot_options -%}
              <button type="button" class="ka-chatbot-option-btn" data-question="{{ option.question }}">{{ option.label }}</button>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>

      <form class="ka-chatbot-input-form" id="ka-chatbot-form">
        {%- if chatbot_placeholder != blank -%}
          <input type="text" id="ka-chatbot-input" placeholder="{{ chatbot_placeholder }}" required autocomplete="off">
        {%- else -%}
          <input type="text" id="ka-chatbot-input" required autocomplete="off">
        {%- endif -%}
        <button type="submit" class="ka-chatbot-send-btn" aria-label="Send message">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <line x1="22" y1="2" x2="11" y2="13"></line>
            <polygon points="22 2 15 22 11 13 2 9 22 2"></polygon>
          </svg>
        </button>
      </form>
    </div>
  </div>
{%- endif -%}

{% comment %}
  product-card.liquid — Custom premium product card for the blog theme
  Usage: {% render 'product-card', product: product %}
{% endcomment %}
{%- liquid
  assign product_image = product.featured_image | default: product.images.first
  assign product_title = product.title
  assign product_url = product.url
  assign product_price = product.price | money
  assign product_desc = product.metafields.custom.short_description | default: product.description | default: product.content | strip_html | truncate: 160
-%}
<div class="ka-blog-product-card">
  <a href="{{ product_url }}" class="ka-blog-product-card__inner">
    <div class="ka-blog-product-card__image">
      {%- if product_image -%}
        <img src="{{ product_image | image_url: width: 240 }}" alt="{{ product_title | escape }}" loading="lazy" width="120" height="120">
      {%- endif -%}
    </div>
    <div class="ka-blog-product-card__info">
      <h3 class="ka-blog-product-card__title">{{ product_title }}</h3>
      {%- if product_desc != blank -%}
        <p class="ka-blog-product-card__desc">{{ product_desc }}</p>
      {%- endif -%}
      <div class="ka-blog-product-card__price">{{ product_price }}</div>
    </div>
  </a>
</div>

{% comment %}
  ka-product-recommendations.liquid — Product grid (meta-driven)
  Usage: {% render 'ka-product-recommendations', article: article, blog: blog %}
{% endcomment %}

{%- liquid
  assign products = article.metafields.custom.recommended_products.value
  assign products_eyebrow = article.metafields.custom.products_eyebrow | default: blog.metafields.custom.products_eyebrow
  assign heading = article.metafields.custom.recommended_products_heading | default: blog.metafields.custom.recommended_products_heading
  assign description = article.metafields.custom.recommended_products_description | default: blog.metafields.custom.recommended_products_description
-%}

{%- if products != blank and products.size > 0 -%}
  <section class="ka-article-products" id="products" aria-labelledby="ka-products-title">
    {%- if products_eyebrow != blank -%}
      <p class="ka-blog-eyebrow">{{ products_eyebrow }}</p>
    {%- endif -%}
    {%- if heading != blank -%}
      <h2 id="ka-products-title">{{ heading }}</h2>
    {%- endif -%}
    {%- if description != blank -%}
      <p class="ka-blog-muted ka-product-desc">{{ description }}</p>
    {%- endif -%}
    <div class="ka-article-product-grid">
      {%- for product in products limit: 3 -%}
        {%- render 'product-card', product: product, is_alternative: true -%}
      {%- endfor -%}
    </div>
  </section>
{%- endif -%}

{% comment %}
  ka-article-disclaimer.liquid — Health disclaimer (meta-driven)
  Usage: {% render 'ka-article-disclaimer', article: article, blog: blog %}
{% endcomment %}

{%- liquid
  assign disclaimer_obj = blog.metafields.custom.health_disclaimer.value
  assign disclaimer_text = disclaimer_obj.content.value | default: disclaimer_obj.content
-%}

{%- if disclaimer_text != blank -%}
  <section class="ka-article-disclaimer ka-section-spaced" id="disclaimer">
    <p>
      {%- if disclaimer_label != blank -%}<b>{{ disclaimer_label }}</b> {%- endif -%}
      {{ disclaimer_text }}
    </p>
  </section>
{%- endif -%}

{% comment %}
  ka-article-disclaimer.liquid — Health disclaimer (meta-driven)
  Usage: {% render 'ka-article-disclaimer', article: article, blog: blog %}
{% endcomment %}

{%- liquid
  assign disclaimer_label = article.metafields.custom.disclaimer_label | default: blog.metafields.custom.disclaimer_label
  assign disclaimer_text = article.metafields.custom.medical_disclaimer.value | default: article.metafields.custom.medical_disclaimer | default: article.metafields.custom.disclaimer.value | default: article.metafields.custom.disclaimer | default: blog.metafields.custom.default_disclaimer
-%}

{%- if disclaimer_text != blank -%}
  <section class="ka-article-disclaimer ka-section-spaced" id="disclaimer">
    <p>
      {%- if disclaimer_label != blank -%}<b>{{ disclaimer_label }}</b> {%- endif -%}
      {{ disclaimer_text }}
    </p>
  </section>
{%- endif -%}

{% comment %}
  ka-article-disclaimer.liquid — Health disclaimer (meta-driven)
  Usage: {% render 'ka-article-disclaimer', article: article, blog: blog %}
{% endcomment %}

{%- liquid
  assign disclaimer_label = article.metafields.custom.disclaimer_label | default: blog.metafields.custom.disclaimer_label | default: 'Health disclaimer:'
  assign custom_disclaimer = article.metafields.custom.medical_disclaimer.value | default: article.metafields.custom.medical_disclaimer | default: article.metafields.custom.disclaimer.value | default: article.metafields.custom.disclaimer | default: blog.metafields.custom.health_disclaimer.value.content.value | default: blog.metafields.custom.health_disclaimer.value.content
  assign default_disclaimer = 'Ayurveda guidance on Kerala Ayurveda is supportive care, not emergency or diagnostic medical treatment.'
  assign disclaimer_text = custom_disclaimer | default: default_disclaimer
  
  assign disclaimer_text = disclaimer_text | replace: 'on AyurHQ', 'on Kerala Ayurveda' | replace: 'on DhyanHQ', 'on Kerala Ayurveda' | replace: 'AyurHQ', 'Kerala Ayurveda' | replace: 'DhyanHQ', 'Kerala Ayurveda' | replace: '  ', ' ' | strip
-%}

{%- if disclaimer_text != blank -%}
  <section class="ka-article-disclaimer ka-section-spaced" id="disclaimer">
    <p>
      {%- if disclaimer_label != blank -%}<b>{{ disclaimer_label }}</b> {%- endif -%}
      {{ disclaimer_text }}
    </p>
  </section>
{%- endif -%}

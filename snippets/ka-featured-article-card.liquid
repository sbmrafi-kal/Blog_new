{% comment %}
  ka-featured-article-card.liquid — Two-column featured article card
  Usage: {% render 'ka-featured-article-card', article: article, blog: blog %}
  All labels meta-driven via blog.metafields.custom.*
{% endcomment %}

{%- liquid
  assign featured = article
  assign raw_chip = featured.metafields.custom.hero_badge.value | default: featured.metafields.custom.hero_badge | default: featured.metafields.custom.category_label | default: featured.tags.first
  assign chip_downcase = raw_chip | downcase
  if chip_downcase == 'doshas' or chip_downcase == 'dosha'
    assign chip_text = blank
  else
    assign chip_text = raw_chip
  endif
  assign dek = featured.metafields.custom.dek | default: featured.excerpt_or_content | strip_html | truncate: 200
  assign read_time = featured.metafields.custom.read_time.value | default: featured.metafields.custom.read_time | default: featured.metafields.custom.read_time_minutes
  assign author_profile = featured.metafields.custom.written_by_profile.value
  assign author_name = author_profile.name | default: featured.author
  assign read_full_label = blog.metafields.custom.read_full_label | default: 'Read full article'
  assign by_label = blog.metafields.custom.by_label | default: 'By'
  assign min_read_label = blog.metafields.custom.min_read_label | default: 'min read'

  # Image resolution order: metafield custom.hero_image, standard article image, or fallback
  assign featured_image = featured.metafields.custom.hero_image.value | default: featured.metafields.custom.hero_image | default: featured.image
-%}

<a class="ka-blog-feature-card" href="{{ featured.url }}">
  <div class="ka-blog-feature-copy">
    <h2>{{ featured.title }}</h2>
    {%- if dek != blank -%}
      <p>{{ dek }}</p>
    {%- endif -%}
    <div class="ka-blog-meta-line">
      {%- if author_name != blank -%}
        {%- unless author_name contains 'Editorial Team' or author_name contains 'Editorial' -%}
          <span>{{ by_label }} {{ author_name }}</span>
        {%- endunless -%}
      {%- endif -%}
      {%- if read_time -%}
        {%- if read_time contains 'min' or read_time contains 'read' -%}
          <span>{{ read_time }}</span>
        {%- else -%}
          <span>{{ read_time }} {{ min_read_label }}</span>
        {%- endif -%}
      {%- endif -%}
      <span>Pub. Date : {{ featured.published_at | date: "%B %d, %Y" }}</span>
    </div>
    <span class="ka-blog-read-more">{{ read_full_label }}</span>
  </div>
  <div class="ka-blog-feature-card__image">
    {%- if featured_image != blank -%}
      <img
        src="{{ featured_image | image_url: width: 800 }}"
        alt="{{ featured_image.alt | default: featured.title | escape }}"
        loading="eager"
        fetchpriority="high"
        width="800"
      >
    {%- else -%}
      {%- comment -%} Fallback to a mock image based on article title length modulo {%- endcomment -%}
      {%- assign fallback_num = featured.title.size | modulo: 4 -%}
      {%- if fallback_num == 0 -%}
        {%- assign fallback_img = 'ginger.webp' -%}
      {%- elsif fallback_num == 1 -%}
        {%- assign fallback_img = 'cumin.webp' -%}
      {%- elsif fallback_num == 2 -%}
        {%- assign fallback_img = 'fennel.webp' -%}
      {%- else -%}
        {%- assign fallback_img = 'coriander.webp' -%}
      {%- endif -%}
      <img
        src="{{ fallback_img | asset_url }}"
        alt="{{ featured.title | escape }}"
        loading="eager"
        fetchpriority="high"
        width="800"
      >
    {%- endif -%}
  </div>
</a>

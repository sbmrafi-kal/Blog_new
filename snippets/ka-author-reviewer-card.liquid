{% comment %}
  ka-author-reviewer-card.liquid — Author/reviewer profile card (meta-driven)
  Usage: {% render 'ka-author-reviewer-card', profile: profile, role_label: role_label, blog: blog %}
{% endcomment %}

{%- liquid
  assign person = profile
  assign person_name = person.name
  assign person_role = person.role_label | default: role_label
  assign person_designation = person.designation
  assign person_degree = person.degree
  assign person_qualifications = person.qualifications
  assign person_bio = person.short_bio
  assign person_photo = person.photo
  assign person_url = person.profile_url
  assign person_initials = person_name | split: ' ' | map: 'first' | join: '' | upcase | truncate: 2, ''
  assign view_profile_label = blog.metafields.custom.view_profile_label
-%}

{%- if person_name != blank -%}
  <section class="ka-article-author-card" id="{{ role_label | handleize }}">
    <div class="ka-article-avatar" aria-hidden="true">
      {%- if person_photo -%}
        <img
          src="{{ person_photo | image_url: width: 176 }}"
          alt="{{ person_name | escape }}"
          loading="lazy"
          width="88"
          height="88"
        >
      {%- else -%}
        {{ person_initials }}
      {%- endif -%}
    </div>
    <div>
      {%- if person_role != blank -%}
        <p class="ka-blog-eyebrow">{{ person_role }}</p>
      {%- endif -%}
      <h2>{{ person_name }}</h2>
      {%- if person_degree != blank or person_qualifications != blank -%}
        <p class="ka-blog-muted ka-author-credentials">
          <b>
            {%- if person_degree != blank -%}{{ person_degree }}{%- endif -%}
            {%- if person_degree != blank and person_qualifications != blank -%} · {%- endif -%}
            {%- if person_qualifications != blank -%}{{ person_qualifications }}{%- endif -%}
          </b>
        </p>
      {%- endif -%}
      {%- if person_bio != blank -%}
        <p class="ka-author-bio">{{ person_bio }}</p>
      {%- endif -%}
      {%- if person_url != blank and view_profile_label != blank -%}
        <div class="ka-blog-chip-row ka-author-actions">
          <a href="{{ person_url }}" class="ka-blog-chip ka-blog-chip--green">{{ view_profile_label }}</a>
        </div>
      {%- endif -%}
    </div>
  </section>
{%- endif -%}

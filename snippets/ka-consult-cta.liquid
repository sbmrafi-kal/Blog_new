{% comment %}
  ka-consult-cta.liquid — Vaidya consultation CTA block (meta-driven)
  Usage: {% render 'ka-consult-cta', blog: blog %}
{% endcomment %}

{%- liquid
  assign cta_title = blog.metafields.custom.consult_cta_title
  assign cta_text = blog.metafields.custom.consult_cta_text
  assign cta_button = blog.metafields.custom.consult_cta_button_label
  assign cta_url = blog.metafields.custom.consult_cta_url
  assign steps = blog.metafields.custom.consult_steps.value
-%}

{%- if cta_title != blank -%}
  <section class="ka-blog-section" id="consult">
    <div class="ka-blog-container">
      <div class="ka-blog-consult-card">
        <div>
          <h2>{{ cta_title }}</h2>
          {%- if cta_text != blank -%}
            <p class="ka-blog-lead">{{ cta_text }}</p>
          {%- endif -%}
          {%- if cta_button != blank -%}
            {%- if cta_url != blank -%}
              <a class="ka-blog-btn" href="{{ cta_url }}">{{ cta_button }}</a>
            {%- else -%}
              <span class="ka-blog-btn ka-blog-btn--disabled">{{ cta_button }}</span>
            {%- endif -%}
          {%- endif -%}
        </div>
        {%- if steps != blank and steps.size > 0 -%}
          <div class="ka-blog-steps">
            {%- for step in steps -%}
              <div class="ka-blog-step">
                <div class="ka-blog-step-number">{{ forloop.index | prepend: '0' | slice: -2, 2 }}</div>
                <div>
                  <h3>{{ step.title }}</h3>
                  <p class="ka-blog-muted">{{ step.description }}</p>
                </div>
              </div>
            {%- endfor -%}
          </div>
        {%- endif -%}
      </div>
    </div>
  </section>
{%- endif -%}

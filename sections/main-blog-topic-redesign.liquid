{% comment %}
  main-blog-topic-redesign.liquid — Topic/category page section
  Renders when current_tags is present (tag-filtered blog view)
  Template: blog.ayurveda.json (conditionally switches to this when tags exist)

  NOTE: In Shopify OS 2.0, both the blog landing and tagged views share the
  same blog template. Use `current_tags` to conditionally render the topic UI.
  This section is designed to be included in blog.ayurveda.json as a
  separate section that only renders when current_tags is present.
{% endcomment %}

{%- if current_tags -%}
{{ 'ka-blog-redesign.css' | asset_url | stylesheet_tag }}
{%- render 'custom-article-font' -%}

{%- liquid
  assign blog_handle = section.settings.blog | default: blog.handle
  if blog_handle == blank
    assign blog_handle = 'news'
  endif
  assign selected_blog = blog

  assign current_tag = current_tags | first
  assign topic_metaobject = nil

  # Parse topic and care_path query parameters dynamically from content_for_header
  capture content_header
    echo content_for_header
  endcapture
  assign page_url = content_header | split: '"pageurl":"' | last | split: '"' | first

  assign topic_param = ''
  if page_url contains 'topic='
    assign topic_param = page_url | split: 'topic=' | last | split: '&' | first | url_decode | handleize
  endif

  assign care_path_param = ''
  if page_url contains 'care_path='
    assign care_path_param = page_url | split: 'care_path=' | last | split: '&' | first | url_decode | handleize
  endif

  assign path_metaobject = nil
  if care_path_param != blank
    assign care_paths = selected_blog.metafields.custom.care_paths.value
    for cp in care_paths
      assign temp_cp_handle = cp.system.handle | default: cp.handle | default: cp.title | handleize
      if temp_cp_handle == care_path_param
        assign path_metaobject = cp
        break
      endif
    endfor
  endif

  assign topics = selected_blog.metafields.custom.topics.value
  if topics != blank
    if topic_param != blank
      for topic in topics
        assign temp_handle = topic.system.handle | default: topic.handle | default: topic.title | handleize
        if temp_handle == topic_param
          assign topic_metaobject = topic
          break
        endif
      endfor
    endif

    # Fallback to current_tag match if not found by query param
    if topic_metaobject == nil and path_metaobject == nil
      for topic in topics
        if topic.article_filter_tag == current_tag or topic.title == current_tag
          assign topic_metaobject = topic
          break
        endif
      endfor
    endif
  endif

  assign topic_title = topic_metaobject.title | default: current_tag
  assign topic_handle = topic_metaobject.system.handle | default: topic_metaobject.handle | default: topic_param | default: topic_title | handleize

  # Map description overrides
  assign topic_description = topic_metaobject.description
  if topic_description == blank
    if topic_handle contains 'sleep'
      assign topic_description = 'Restore your body’s natural rhythms with classical Ayurvedic sleep wisdom, herbal remedies, and soothing evening routines.'
    elsif topic_handle contains 'digest' or topic_handle contains 'agni'
      assign topic_description = 'Kindle your inner fire (Agni) and eliminate toxins (Ama) with time-tested Ayurvedic diets, spices, and digestive guidelines.'
    elsif topic_handle contains 'herb'
      assign topic_description = 'Discover the healing properties, traditional uses, and modern benefits of classical Ayurvedic herbs like Ashwagandha, Turmeric, and Ginger.'
    elsif topic_handle contains 'detox'
      assign topic_description = 'Rejuvenate your body and clear seasonal congestion with gentle Ayurvedic detoxification practices, herbal drinks, and light foods.'
    elsif topic_handle contains 'skin' or topic_handle contains 'hair' or topic_handle contains 'beauty'
      assign topic_description = 'Nurture your natural beauty from within with cooling Ayurvedic remedies, herbal face packs, and nourishing hair oils.'
    elsif topic_handle contains 'womens-health' or topic_handle contains 'women'
      assign topic_description = 'Support feminine balance, monthly cycles, and hormonal harmony through life’s transitions using nature-based Ayurvedic care.'
    elsif topic_handle contains 'pain-joints' or topic_handle contains 'joints'
      assign topic_description = 'Relieve muscle stiffness, support bone density, and promote flexible joints with classical Ayurvedic massage oils and remedies.'
    elsif topic_handle contains 'dosha' or topic_handle contains 'basics' or topic_handle contains 'prakriti'
      assign topic_description = 'Learn the foundations of Ayurveda, including the three doshas (Vata, Pitta, Kapha) and how to align daily living with your constitution.'
    elsif topic_handle contains 'food' or topic_handle contains 'kitchen'
      assign topic_description = 'Transform your kitchen into a pharmacy with Ayurvedic cooking tips, optimal food combinations, and seasonal recipes.'
    elsif topic_handle contains 'weight' or topic_handle contains 'cravings'
      assign topic_description = 'Achieve healthy weight management and curb strong cravings by balancing your metabolism, portion sizes, and digestive fire.'
    elsif topic_handle contains 'immunity' or topic_handle contains 'resilience'
      assign topic_description = 'Build deep physical resilience and vital energy (Ojas) with traditional Ayurvedic immune-boosting formulations and daily rituals.'
    elsif topic_handle contains 'season' or topic_handle contains 'routine'
      assign topic_description = 'Align your body with nature’s cycles using seasonal routines (Ritucharya) for transitions in cold, hot, and wet climates.'
    elsif topic_handle contains 'mind' or topic_handle contains 'calm' or topic_handle contains 'stress'
      assign topic_description = 'Calm an overactive nervous system, reduce stress, and improve clarity using Ayurvedic herbs, breathing (Pranayama), and meditation.'
    elsif topic_handle contains 'habit' or topic_handle contains 'daily'
      assign topic_description = 'Establish a powerful daily routine (Dinacharya) with classic practices like oil pulling, tongue scraping, and daily body massage.'
    elsif topic_handle contains 'special-senses' or topic_handle contains 'eye' or topic_handle contains 'ear' or topic_handle contains 'mouth' or topic_handle contains 'sensory'
      assign topic_description = 'Protect and rejuvenate your eyes, ears, nose, and mouth with time-tested Ayurvedic sensory therapies.'
    elsif topic_handle contains 'men'
      assign topic_description = 'Enhance male vitality, endurance, reproductive wellness, and physical strength with traditional Ayurvedic herbs and active lifestyle tips.'
    elsif topic_handle contains 'kid' or topic_handle contains 'child'
      assign topic_description = 'Support your child’s growth, natural immunity, and appetite with gentle Ayurvedic herbs and nourishing meals.'
    elsif topic_handle contains 'elder' or topic_handle contains 'old-age'
      assign topic_description = 'Promote longevity, memory retention, joint mobility, and comfortable digestion in the golden years with supportive vata-balancing care.'
    else
      assign topic_description = 'Explore classical Ayurvedic wisdom, custom diet guidelines, and holistic wellness practices for everyday balance and health.'
    endif
  endif

  # Eyebrow defaults to Ayurveda
  assign eyebrow_label = blog.metafields.custom.topic_hero_eyebrow | default: 'Ayurveda'

  # Override with Care Path metadata if active
  if path_metaobject != nil
    assign topic_title = path_metaobject.title.value | default: path_metaobject.title
    assign topic_handle = path_metaobject.system.handle | default: path_metaobject.handle | default: topic_title | handleize
    assign topic_description = path_metaobject.subtitle.value | default: path_metaobject.subtitle
    assign topic_image = path_metaobject.image.value | default: path_metaobject.image
    assign eyebrow_label = 'Care Path'
  endif

  # Retrieve/Map the same dark fallback images as on the main news page
  assign asset_name = ''
  if topic_handle contains 'digestion'
    assign asset_name = 'topic-digestion.jpg'
  elsif topic_handle contains 'food'
    assign asset_name = 'topic-food.jpg'
  elsif topic_handle contains 'herbs'
    assign asset_name = 'topic-herbs.jpg'
  elsif topic_handle contains 'weight' or topic_handle contains 'cravings'
    assign asset_name = 'topic-weight.jpg'
  elsif topic_handle contains 'immunity'
    assign asset_name = 'topic-immunity.jpg'
  elsif topic_handle contains 'seasons' or topic_handle contains 'routine'
    assign asset_name = 'topic-seasons.jpg'
  elsif topic_handle contains 'sleep' or topic_handle contains 'circadian'
    assign asset_name = 'topic-sleep.jpg'
  elsif topic_handle contains 'mind' or topic_handle contains 'calm'
    assign asset_name = 'topic-mind.jpg'
  elsif topic_handle contains 'habits'
    assign asset_name = 'topic-habits.jpg'
  elsif topic_handle contains 'joints' or topic_handle contains 'body' or topic_handle contains 'pain'
    assign asset_name = 'topic-joints.jpg'
  elsif topic_handle contains 'skin' or topic_handle contains 'glow'
    assign asset_name = 'topic-skin.jpg'
  elsif topic_handle contains 'hair' or topic_handle contains 'scalp'
    assign asset_name = 'topic-hair.jpg'
  elsif topic_handle contains 'senses' or topic_handle contains 'eyes' or topic_handle contains 'ears' or topic_handle contains 'mouth'
    assign asset_name = 'topic-senses.jpg'
  elsif topic_handle contains 'women'
    assign asset_name = 'topic-women.jpg'
  elsif topic_handle contains 'men'
    assign asset_name = 'topic-men.jpg'
  elsif topic_handle contains 'kids' or topic_handle contains 'children'
    assign asset_name = 'topic-kids.jpg'
  elsif topic_handle contains 'elder'
    assign asset_name = 'topic-elders.jpg'
  elsif topic_handle contains 'basics' or topic_handle contains 'ayurveda'
    assign asset_name = 'topic-basics.jpg'
  endif

  assign fallback_img = ''
  if asset_name != blank
    assign fallback_img = asset_name | asset_url
  else
    assign fallback_img = 'topic-basics.jpg' | asset_url
  endif

  # Image gets overridden above for Care Paths, but dereference/url check remains correct
  assign topic_img_url = ''
  if topic_image != blank
    assign topic_img_url = topic_image | image_url: width: 800
  endif

  # Force fallback dark assets for Seasons and Sleep
  if topic_handle contains 'seasons' or topic_handle contains 'routine'
    assign topic_img_url = ''
  endif
  if topic_handle contains 'sleep' or topic_handle contains 'circadian'
    assign topic_img_url = ''
  endif

  assign topic_secondary_label = topic_metaobject.secondary_label
-%}

<div class="ka-blog-wrapper">

  <section class="ka-blog-section--tight" id="overview">
    <div class="ka-blog-container">
      <article class="ka-blog-topic-hero">
        <div class="ka-blog-topic-hero__content">
          <p class="ka-blog-eyebrow">
            {{ eyebrow_label }}
            {%- if topic_secondary_label != blank and path_metaobject == nil -%}
              <span class="ka-hindi"> · {{ topic_secondary_label }}</span>
            {%- endif -%}
          </p>
          <h1>{{ topic_title }}</h1>
          {%- if topic_description != blank -%}
            <p class="ka-blog-lead">{{ topic_description }}</p>
          {%- endif -%}
        </div>
        <div class="ka-blog-topic-hero__image-wrap">
          {%- if topic_img_url != blank -%}
            <img src="{{ topic_img_url }}" alt="{{ topic_title | escape }}" loading="eager" fetchpriority="high">
          {%- else -%}
            <img src="{{ fallback_img }}" alt="{{ topic_title | escape }}" loading="eager" fetchpriority="high">
          {%- endif -%}
        </div>
      </article>
    </div>
  </section>

  {%- if path_metaobject != nil -%}
    {%- liquid
      # Define phase title, description, and list for each main concern
      assign phase_1_title = "Cleanse & Prep"
      assign phase_1_desc = "Clear internal toxins (Ama) and prepare the body for nourishment."
      assign phase_2_title = "Nourish & Balance"
      assign phase_2_desc = "Feed the tissues, balance the active doshas, and restore organ function."
      assign phase_3_title = "Rejuvenate & Sustain"
      assign phase_3_desc = "Cultivate deep immunity (Ojas) and prevent future imbalances."
      
      assign topic_handle_lower = topic_handle | downcase
      if topic_handle_lower contains 'digest'
        assign phase_1_title = "Kindle Digestive Fire (Agni)"
        assign phase_1_desc = "Sip warm ginger water and eat light, fresh foods to clear toxic build-up (Ama)."
        assign phase_2_title = "Balance Gut Flora"
        assign phase_2_desc = "Integrate cooling spices, home-cooked meals, and natural buttermilk (Takra)."
        assign phase_3_title = "Rebuild Ojas (Immunity)"
        assign phase_3_desc = "Restore vitality and absorption with daily ghee, nourishing herbs, and mindfulness."
      elsif topic_handle_lower contains 'sleep' or topic_handle_lower contains 'stress' or topic_handle_lower contains 'mind'
        assign phase_1_title = "Calm Vata (Nervous System)"
        assign phase_1_desc = "Massage feet with warm oil (Abhyanga) and power down all digital screens by 9 PM."
        assign phase_2_title = "Nourish the Mind"
        assign phase_2_desc = "Sip warm milk with Ashwagandha and practice deep alternate nostril breathing."
        assign phase_3_title = "Establish Daily Rhythms"
        assign phase_3_desc = "Align sleep-wake cycles with nature and maintain calm physical resilience."
      elsif topic_handle_lower contains 'joint' or topic_handle_lower contains 'pain' or topic_handle_lower contains 'body'
        assign phase_1_title = "Reduce Stiffness"
        assign phase_1_desc = "Apply warm herbal oils and perform gentle circular self-massage on affected areas."
        assign phase_2_title = "Strengthen Tissues"
        assign phase_2_desc = "Incorporate Vata-balancing foods, warm broths, and bone-strengthening Ayurvedic herbs."
        assign phase_3_title = "Maintain Flexibility"
        assign phase_3_desc = "Engage in light, fluid movements, joint lubrication exercises, and regular oiling."
      elsif topic_handle_lower contains 'skin' or topic_handle_lower contains 'hair' or topic_handle_lower contains 'beauty'
        assign phase_1_title = "Purify Blood (Rakta)"
        assign phase_1_desc = "Consume bitter greens and detoxifying teas to purge excess internal heat (Pitta)."
        assign phase_2_title = "Deeply Nourish Roots"
        assign phase_2_desc = "Massage scalp or skin with classical oils, and use natural cooling clay or herbal masks."
        assign phase_3_title = "Cultivate Natural Glow"
        assign phase_3_desc = "Retain optimal hydration, balance sleep, and support collagen production organically."
      endif
    -%}
    <section class="ka-blog-section" id="care-path-journey" style="padding-top: 0 !important;">
      <div class="ka-blog-container">
        <div class="ka-care-journey-card">
          <div class="ka-care-journey-badge">Your Health Pathway</div>
          <h2>Ayurvedic Care Journey</h2>
          <p class="ka-care-journey-intro">Follow this expert-designed 3-phase progression to restore balance for your concern:</p>
          
          <div class="ka-care-journey-steps">
            <div class="ka-care-journey-step">
              <div class="ka-care-step-num">01</div>
              <div class="ka-care-step-content">
                <h4>{{ phase_1_title }}</h4>
                <p>{{ phase_1_desc }}</p>
              </div>
            </div>
            
            <div class="ka-care-journey-step-connector"></div>
            
            <div class="ka-care-journey-step">
              <div class="ka-care-step-num">02</div>
              <div class="ka-care-step-content">
                <h4>{{ phase_2_title }}</h4>
                <p>{{ phase_2_desc }}</p>
              </div>
            </div>
            
            <div class="ka-care-journey-step-connector"></div>
            
            <div class="ka-care-journey-step">
              <div class="ka-care-step-num">03</div>
              <div class="ka-care-step-content">
                <h4>{{ phase_3_title }}</h4>
                <p>{{ phase_3_desc }}</p>
              </div>
            </div>
          </div>
          
          <div class="ka-care-journey-footer">
            <div class="ka-care-journey-footer-text">
              <strong>Need personalized advice?</strong> Get a custom care pathway tailored specifically to your body constitution (Prakriti) from our certified Vaidyas.
            </div>
            <a href="#consult" class="ka-blog-btn ka-care-journey-btn">Consult Vaidya</a>
          </div>
        </div>
      </div>
    </section>
  {%- endif -%}

  {%- comment -%} ============ ARTICLES IN TOPIC ============ {%- endcomment -%}
  <section class="ka-blog-section--tight" id="articles">
    <div class="ka-blog-container">

      {%- liquid
        # 1. Build a list of all major topic filter tags and titles to exclude them from sub-filters
        assign major_topic_tags = ""
        assign major_topics = selected_blog.metafields.custom.topics.value
        for t_obj in major_topics
          assign mt_tag = t_obj.article_filter_tag | strip
          assign mt_title = t_obj.title | strip
          if mt_tag != blank
            assign major_topic_tags = major_topic_tags | append: "," | append: mt_tag
          endif
          if mt_title != blank
            assign major_topic_tags = major_topic_tags | append: "," | append: mt_title
          endif
        endfor
        
        # Also add administrative tags to the blacklist
        assign major_topic_tags = major_topic_tags | append: ",Feature,Essay,Reading guide,Ayurveda,Journal,Popular,All"
        assign blacklist_tags = major_topic_tags | split: "," | uniq

        # 2. Extract related tags from article tags, skipping blacklisted tags
        assign related_tags = ""
        for article in selected_blog.articles
          for t in article.tags
            assign t_clean = t | strip
            if t_clean != current_tag
              assign is_blacklisted = false
              for bl_tag in blacklist_tags
                if bl_tag == t_clean
                  assign is_blacklisted = true
                  break
                endif
              endfor
              unless is_blacklisted
                assign related_tags = related_tags | append: "," | append: t_clean
              endunless
            endif
          endfor
        endfor
        assign related_tags_array = related_tags | split: "," | uniq | compact
      -%}

      {%- paginate selected_blog.articles by 9 -%}
        <div class="ka-blog-section-head" style="margin-top: 18px;">
          <div>
            <p class="ka-blog-eyebrow">
              {{ paginate.items }} articles
            </p>
            <h2>{{ topic_metaobject.guides_heading | default: 'Guides in this topic' }}</h2>
          </div>
        </div>

        {%- comment -%} Filter bar from dynamic related tags {%- endcomment -%}
        {%- if related_tags_array.size > 0 -%}
          <nav class="ka-blog-filter-bar" aria-label="{{ topic_title }} filters">
            {%- assign current_tag_handle = current_tag | handleize -%}
            {%- assign all_filter_url = selected_blog.url | append: '/tagged/' | append: current_tag_handle -%}
            {%- if path_metaobject != nil -%}
              {%- assign all_filter_url = all_filter_url | append: '?care_path=' | append: topic_handle -%}
            {%- elsif topic_handle != blank -%}
              {%- assign all_filter_url = all_filter_url | append: '?topic=' | append: topic_handle -%}
            {%- endif -%}
            <a class="{% if current_tags.size == 1 %}active{% endif %}" href="{{ all_filter_url }}">{{ selected_blog.metafields.custom.filter_all_label | default: 'All' }}</a>
            {%- for tag in related_tags_array -%}
              {%- assign trimmed_tag = tag | strip -%}
              {%- if trimmed_tag != blank -%}
                {%- assign is_active = false -%}
                {%- if current_tags contains trimmed_tag -%}
                  {%- assign is_active = true -%}
                {%- endif -%}
                {%- assign trimmed_tag_handle = trimmed_tag | handleize -%}
                {%- assign sub_filter_url = selected_blog.url | append: '/tagged/' | append: current_tag_handle | append: '+' | append: trimmed_tag_handle -%}
                {%- if path_metaobject != nil -%}
                  {%- assign sub_filter_url = sub_filter_url | append: '?care_path=' | append: topic_handle -%}
                {%- elsif topic_handle != blank -%}
                  {%- assign sub_filter_url = sub_filter_url | append: '?topic=' | append: topic_handle -%}
                {%- endif -%}
                <a class="{% if is_active %}active{% endif %}" href="{{ sub_filter_url }}">{{ trimmed_tag }}</a>
              {%- endif -%}
            {%- endfor -%}
          </nav>
        {%- endif -%}

        <div class="ka-blog-article-grid" style="margin-top: 24px;">
          {%- for article in selected_blog.articles -%}
            {%- liquid
              # If path_metaobject is active, filter articles by the care path's linked topic
              if path_metaobject != nil
                assign linked_topic_handle = path_metaobject.linked_topic.value.system.handle | default: path_metaobject.linked_topic.value.handle | default: path_metaobject.linked_topic.system.handle | default: path_metaobject.linked_topic.handle | default: path_metaobject.linked_topic.title | handleize
                assign article_topic = article.metafields.custom.topic.value | default: article.metafields.custom.topic
                assign article_topic_handle = article_topic.system.handle | default: article_topic.handle | default: article_topic.title | handleize
                if article_topic_handle != blank and article_topic_handle != linked_topic_handle
                  continue
                endif
              # Else if topic_metaobject is active, filter articles by the active topic
              elsif topic_metaobject != nil
                assign article_topic = article.metafields.custom.topic.value | default: article.metafields.custom.topic
                assign article_topic_handle = article_topic.system.handle | default: article_topic.handle | default: article_topic.title | handleize
                if article_topic_handle != blank and article_topic_handle != topic_handle
                  continue
                endif
              endif
            -%}
            {%- render 'ka-blog-card', article: article -%}
          {%- endfor -%}
        </div>

        {%- if paginate.pages > 1 -%}
          <nav class="ka-blog-pagination" aria-label="Topic pagination">
            {%- if paginate.previous -%}
              {%- assign prev_url = paginate.previous.url -%}
              {%- if topic_handle != blank -%}
                {%- if prev_url contains '?' -%}
                  {%- assign prev_url = prev_url | append: '&topic=' | append: topic_handle -%}
                {%- else -%}
                  {%- assign prev_url = prev_url | append: '?topic=' | append: topic_handle -%}
                {%- endif -%}
              {%- endif -%}
              <a href="{{ prev_url }}#articles">← Previous</a>
            {%- endif -%}
            {%- for part in paginate.parts -%}
               {%- if part.is_link -%}
                {%- assign part_url = part.url -%}
                {%- if topic_handle != blank -%}
                  {%- if part_url contains '?' -%}
                    {%- assign part_url = part_url | append: '&topic=' | append: topic_handle -%}
                  {%- else -%}
                    {%- assign part_url = part_url | append: '?topic=' | append: topic_handle -%}
                  {%- endif -%}
                {%- endif -%}
                <a href="{{ part_url }}#articles">{{ part.title }}</a>
              {%- else -%}
                {%- if part.title == paginate.current_page -%}
                  <span class="current">{{ part.title }}</span>
                {%- else -%}
                  <span class="deco">{{ part.title }}</span>
                {%- endif -%}
              {%- endif -%}
            {%- endfor -%}
            {%- if paginate.next -%}
              {%- assign next_url = paginate.next.url -%}
              {%- if topic_handle != blank -%}
                {%- if next_url contains '?' -%}
                  {%- assign next_url = next_url | append: '&topic=' | append: topic_handle -%}
                {%- else -%}
                  {%- assign next_url = next_url | append: '?topic=' | append: topic_handle -%}
                {%- endif -%}
              {%- endif -%}
              <a href="{{ next_url }}#articles">Next →</a>
            {%- endif -%}
          </nav>
        {%- endif -%}
      {%- endpaginate -%}
    </div>
  </section>

  {%- comment -%} ============ CONSULT CTA ============ {%- endcomment -%}
  {%- render 'ka-consult-cta', blog: selected_blog, section: section -%}

  {%- comment -%} ============ CHATBOT ============ {%- endcomment -%}
  {%- render 'ka-chatbot', blog: selected_blog -%}
</div>

<script src="{{ 'ka-blog-redesign.js' | asset_url }}" defer></script>
{%- endif -%}

{% schema %}
{
  "name": "Blog Topic — Redesign",
  "tag": "section",
  "class": "ka-blog-topic-section",
  "settings": [
    {
      "type": "blog",
      "id": "blog",
      "label": "Blog to fetch articles from"
    }
  ],
  "templates": ["blog"]
}
{% endschema %}

{% comment %}
  main-article-redesign.liquid — Full redesigned article section
  Renders: breadcrumbs, hero, two-column layout (content + TOC sidebar),
  at-a-glance, article body, products, glossary, sources, disclaimer,
  FAQ, author/reviewer, related articles, share, comments
  Template: article.ayurveda.json
{% endcomment %}

{{ 'ka-blog-redesign.css' | asset_url | stylesheet_tag }}
{%- render 'custom-article-font' -%}

{%- liquid
  assign category_label = article.metafields.custom.hero_badge.value | default: article.metafields.custom.hero_badge | default: article.metafields.custom.category_label | default: article.tags.first
  assign topic = article.metafields.custom.topic.value
  assign topic_title = topic.title | default: category_label
  assign topic_tag = topic.article_filter_tag | default: category_label | handleize
  assign author_profile = article.metafields.custom.written_by_profile.value
  assign reviewer_profile = article.metafields.custom.reviewed_by.value

  assign breadcrumb_home = blog.metafields.custom.breadcrumb_home_label | default: 'Journal'
  assign subnav_overview = blog.metafields.custom.subnav_overview | default: 'Overview'
  assign subnav_care_paths = blog.metafields.custom.subnav_care_paths | default: 'Care paths'
  assign subnav_topics = blog.metafields.custom.subnav_topics | default: 'Topics'
  assign subnav_latest = blog.metafields.custom.subnav_latest | default: 'Latest articles'
  assign subnav_consult = blog.metafields.custom.subnav_consult | default: 'Consult'
  assign toc_heading = blog.metafields.custom.toc_heading | default: 'In this article'
  assign toc_mobile_label = blog.metafields.custom.toc_mobile_label | default: 'Table of contents'
  assign share_label = blog.metafields.custom.share_label | default: 'Share this guide:'
  assign written_by_label = blog.metafields.custom.written_by_label | default: 'Written by'
  assign reviewed_by_label = blog.metafields.custom.reviewed_by_label | default: 'Reviewed by'
-%}

<div class="ka-blog-wrapper">

  {%- comment -%} ============ SUBNAV ============ {%- endcomment -%}
  <div class="ka-blog-subnav-wrap">
    <div class="ka-blog-container">
      <nav class="ka-blog-subnav" aria-label="Blog section navigation">
        <a href="{{ blog.url }}#overview">{{ subnav_overview }}</a>
        <a href="{{ blog.url }}#care-paths">{{ subnav_care_paths }}</a>
        <a href="{{ blog.url }}#topics">{{ subnav_topics }}</a>
        <a href="{{ blog.url }}#latest">{{ subnav_latest }}</a>
        <a href="{{ blog.url }}#consult">{{ subnav_consult }}</a>
      </nav>
    </div>
  </div>

  {%- comment -%} ============ BREADCRUMB + ARTICLE HERO ============ {%- endcomment -%}
  <section class="ka-blog-section--tight">
    <div class="ka-blog-container">
      {%- render 'ka-article-hero', article: article, blog: blog -%}
    </div>
  </section>

  {%- comment -%} ============ TWO-COLUMN LAYOUT ============ {%- endcomment -%}
  <section class="ka-blog-section--tight">
    <div class="ka-blog-container ka-article-layout">

      {%- comment -%} ===== MAIN CONTENT COLUMN ===== {%- endcomment -%}
      <article class="ka-article-content">

        {%- comment -%} Mobile TOC (hidden on desktop via CSS) {%- endcomment -%}
        <div class="ka-article-toc-mobile">
          <button
            class="ka-article-toc-mobile__toggle"
            aria-expanded="false"
            aria-controls="ka-mobile-toc-content"
          >
            <span>{{ toc_mobile_label }}</span>
            <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
              <path d="M4 6L8 10L12 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
            </svg>
          </button>
          <div id="ka-mobile-toc-content" class="ka-article-toc-mobile__content">
            <ul class="ka-article-toc-mobile__list">
              {%- comment -%} Built by JS {%- endcomment -%}
            </ul>
          </div>
        </div>

        {%- comment -%} At a glance {%- endcomment -%}
        {%- render 'ka-article-at-a-glance', article: article -%}

        {%- comment -%} Article body content — prefer metafield, fallback to article.content {%- endcomment -%}
        <div class="ka-article-body prose">
          {%- liquid
            assign meta_body = article.metafields.custom.article_body
            if meta_body != blank
              echo meta_body | metafield_tag
            else
              echo article.content
            endif
          -%}
        </div>

        {%- comment -%} Product recommendations {%- endcomment -%}
        {%- render 'ka-product-recommendations', article: article -%}

        {%- comment -%} Glossary {%- endcomment -%}
        {%- render 'ka-glossary-terms', article: article -%}

        {%- comment -%} Sources {%- endcomment -%}
        {%- render 'ka-article-sources', article: article -%}

        {%- comment -%} Health disclaimer {%- endcomment -%}
        {%- render 'ka-article-disclaimer', article: article, section: section -%}

        {%- comment -%} FAQ {%- endcomment -%}
        {%- render 'ka-article-faqs', article: article -%}

        {%- comment -%} Author card {%- endcomment -%}
        {%- assign show_author = true -%}
        {%- assign author_name_str = author_profile.name | default: article.author -%}
        {%- if author_name_str contains 'Editorial Team' or author_name_str contains 'Editorial' -%}
          {%- assign show_author = false -%}
        {%- endif -%}
        {%- if show_author -%}
          {%- if author_profile -%}
            {%- render 'ka-author-reviewer-card',
              profile: author_profile,
              role_label: written_by_label,
              fallback_name: article.author
            -%}
          {%- else -%}
            {%- comment -%} Fallback: show basic author info from article.author {%- endcomment -%}
            {%- if article.author != blank -%}
              <section class="ka-article-author-card" id="author">
                <div class="ka-article-avatar" aria-hidden="true">
                  {{ article.author | split: ' ' | first | slice: 0 | upcase }}{{ article.author | split: ' ' | last | slice: 0 | upcase }}
                </div>
                <div>
                  <p class="ka-blog-eyebrow">{{ written_by_label }}</p>
                  <h2>{{ article.author }}</h2>
                </div>
              </section>
            {%- endif -%}
          {%- endif -%}
        {%- endif -%}

        {%- comment -%} Reviewer card {%- endcomment -%}
        {%- if reviewer_profile -%}
          {%- render 'ka-author-reviewer-card',
            profile: reviewer_profile,
            role_label: reviewed_by_label
          -%}
        {%- else -%}
          {%- assign review_label = article.metafields.custom.review_label.value | default: article.metafields.custom.review_label -%}
          {%- if review_label != blank -%}
            <section class="ka-article-author-card" id="reviewer">
              <div class="ka-article-avatar" aria-hidden="true">
                RV
              </div>
              <div>
                <p class="ka-blog-eyebrow">{{ reviewed_by_label }}</p>
                <h2>{{ review_label | replace: 'Reviewed by ', '' | replace: 'Reviewed by', '' | strip }}</h2>
              </div>
            </section>
          {%- endif -%}
        {%- endif -%}

        {%- comment -%} Related articles {%- endcomment -%}
        {%- render 'ka-related-articles', article: article, blog: blog -%}

        {%- comment -%} Share row {%- endcomment -%}
        <section class="ka-article-share-row" aria-label="Share article">
          <span class="ka-blog-small"><b>{{ share_label }}</b></span>
          <a href="mailto:?subject={{ article.title | url_encode }}&body={{ shop.url }}{{ article.url | url_encode }}" aria-label="Share via email">Email</a>
          <a href="https://www.linkedin.com/sharing/share-offsite/?url={{ shop.url }}{{ article.url | url_encode }}" target="_blank" rel="noopener noreferrer" aria-label="Share on LinkedIn">LinkedIn</a>
          <a href="https://www.facebook.com/sharer/sharer.php?u={{ shop.url }}{{ article.url | url_encode }}" target="_blank" rel="noopener noreferrer" aria-label="Share on Facebook">Facebook</a>
          <a href="https://api.whatsapp.com/send?text={{ article.title | url_encode }}%20{{ shop.url }}{{ article.url | url_encode }}" target="_blank" rel="noopener noreferrer" aria-label="Share on WhatsApp">WhatsApp</a>
        </section>

        {%- comment -%} Comments {%- endcomment -%}
        {%- render 'ka-article-comments', article: article, blog: blog -%}

      </article>

      {%- comment -%} ===== SIDEBAR (Desktop TOC) ===== {%- endcomment -%}
      <aside class="ka-article-sidebar" aria-label="Article table of contents">
        <h3>{{ toc_heading }}</h3>
        <ul class="ka-article-sidebar__list" style="list-style: none; padding: 0; margin: 0;">
          {%- comment -%} Built dynamically by ka-blog-redesign.js {%- endcomment -%}
        </ul>
      </aside>

    </div>
  </section>

  {%- comment -%} ============ FLOATING CTA ============ {%- endcomment -%}
  {%- liquid
    assign floating_cta_label = blog.metafields.custom.floating_cta_label | default: 'Ask an Ayurvedic doctor'
    assign floating_cta_url = blog.metafields.custom.floating_cta_url | default: blog.url | append: '#consult'
  -%}
  <a class="ka-blog-floating-cta" href="{{ floating_cta_url }}">{{ floating_cta_label }}</a>

</div>

<script src="{{ 'ka-blog-redesign.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Article — Redesign",
  "tag": "section",
  "class": "ka-article-main-section",
  "settings": [
    {
      "type": "header",
      "content": "Disclaimer"
    },
    {
      "type": "textarea",
      "id": "default_disclaimer",
      "label": "Default health disclaimer",
      "default": "This content is for informational and educational purposes only. It is not intended as medical advice and should not replace consultation with a qualified healthcare professional. Kerala Ayurveda recommends consulting a doctor or qualified vaidya before beginning any new wellness routine, especially if you have existing health conditions or are on medication."
    }
  ],
  "blocks": [],
  "templates": ["article"]
}
{% endschema %}

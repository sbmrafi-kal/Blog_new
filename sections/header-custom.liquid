{{ 'section-header-custom.css' | asset_url | stylesheet_tag }}

<header class="theme-header-custom" role="banner">
  <div class="theme-header-custom__inner">
    <div class="theme-header-custom__left">
      <button class="theme-header-custom__menu-btn" type="button" aria-label="Open menu">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </button>
      <nav class="theme-header-custom__nav" aria-label="Primary">
        {%- assign nav_1_title = section.settings.nav_1_title | default: '' -%}
        {%- assign nav_2_title = section.settings.nav_2_title | default: '' -%}
        {%- assign nav_3_title = section.settings.nav_3_title | default: '' -%}
        {%- assign nav_4_title = section.settings.nav_4_title | default: '' -%}
        {%- assign nav_5_title = section.settings.nav_5_title | default: '' -%}

        {%- assign nav_1_url = section.settings.nav_1_url | default: routes.root_url -%}
        {%- assign nav_2_url = section.settings.nav_2_url | default: routes.root_url -%}
        {%- assign nav_3_url = section.settings.nav_3_url | default: routes.root_url -%}
        {%- assign nav_4_url = section.settings.nav_4_url | default: routes.root_url -%}
        {%- assign nav_5_url = section.settings.nav_5_url | default: routes.root_url -%}

        {%- liquid
          assign active_links = 0
          if nav_1_title != blank
            assign active_links = active_links | plus: 1
          endif
          if nav_2_title != blank
            assign active_links = active_links | plus: 1
          endif
          if nav_3_title != blank
            assign active_links = active_links | plus: 1
          endif
          if nav_4_title != blank
            assign active_links = active_links | plus: 1
          endif
          if nav_5_title != blank
            assign active_links = active_links | plus: 1
          endif

          assign rendered_index = 0
        -%}

        {%- if nav_1_title != blank -%}
          {%- assign rendered_index = rendered_index | plus: 1 -%}
          <a class="theme-header-custom__nav-link{% if rendered_index == active_links %} theme-header-custom__nav-link--last{% endif %}" href="{{ nav_1_url }}">{{ nav_1_title }}</a>
        {%- endif -%}
        {%- if nav_2_title != blank -%}
          {%- assign rendered_index = rendered_index | plus: 1 -%}
          <a class="theme-header-custom__nav-link{% if rendered_index == active_links %} theme-header-custom__nav-link--last{% endif %}" href="{{ nav_2_url }}">{{ nav_2_title }}</a>
        {%- endif -%}
        {%- if nav_3_title != blank -%}
          {%- assign rendered_index = rendered_index | plus: 1 -%}
          <a class="theme-header-custom__nav-link{% if rendered_index == active_links %} theme-header-custom__nav-link--last{% endif %}" href="{{ nav_3_url }}">{{ nav_3_title }}</a>
        {%- endif -%}
        {%- if nav_4_title != blank -%}
          {%- assign rendered_index = rendered_index | plus: 1 -%}
          <a class="theme-header-custom__nav-link{% if rendered_index == active_links %} theme-header-custom__nav-link--last{% endif %}" href="{{ nav_4_url }}">{{ nav_4_title }}</a>
        {%- endif -%}
        {%- if nav_5_title != blank -%}
          {%- assign rendered_index = rendered_index | plus: 1 -%}
          <a class="theme-header-custom__nav-link{% if rendered_index == active_links %} theme-header-custom__nav-link--last{% endif %}" href="{{ nav_5_url }}">{{ nav_5_title }}</a>
        {%- endif -%}
      </nav>
    </div>

    <div class="theme-header-custom__center">
      <a class="theme-header-custom__brand" href="{{ routes.root_url }}" aria-label="{{ shop.name }}">
        {%- if section.settings.logo_image != blank -%}
          {{
            section.settings.logo_image
            | image_url: width: 600
            | image_tag: class: 'theme-header-custom__brand-image', loading: 'eager', alt: section.settings.logo_alt
          }}
        {%- else -%}
          {%- assign logo_text = section.settings.logo_text | default: shop.name -%}
          {%- assign logo_parts = logo_text | split: ' ' -%}
          {%- assign logo_first = logo_parts[0] | downcase -%}
          {%- assign logo_rest = logo_parts | slice: 1, logo_parts.size | join: ' ' | downcase -%}
          <span class="theme-header-custom__brand-text">
            <span class="brand-line brand-line--top">{{ logo_first }}</span>
            {%- if logo_rest != blank -%}
              <span class="brand-line brand-line--bottom">{{ logo_rest }}</span>
            {%- endif -%}
          </span>
        {%- endif -%}
      </a>
    </div>

    <div class="theme-header-custom__right">
      <button class="theme-header-custom__action" type="button" aria-label="Search">
        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <circle cx="11" cy="11" r="7" stroke="currentColor" stroke-width="1.8"></circle>
          <path d="m21 21-4.35-4.35" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"></path>
        </svg>
      </button>
      <a class="theme-header-custom__action theme-header-custom__action--account" href="{{ routes.account_url }}" aria-label="Account">
        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <circle cx="12" cy="8" r="5" stroke="currentColor" stroke-width="1.8"></circle>
          <path d="M20 21a8 8 0 0 0-16 0" stroke="currentColor" stroke-width="1.8" stroke-linecap="round"></path>
        </svg>
      </a>
      <a class="theme-header-custom__action" href="{{ routes.cart_url }}" aria-label="Cart">
        <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
          <circle cx="8" cy="21" r="1" stroke="currentColor" stroke-width="1.6"></circle>
          <circle cx="19" cy="21" r="1" stroke="currentColor" stroke-width="1.6"></circle>
          <path d="M2.05 2.05h2l2.66 12.42a2 2 0 0 0 2 1.58h9.78a2 2 0 0 0 1.95-1.57l1.65-7.43H5.12" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"></path>
        </svg>
        {%- if cart.item_count > 0 -%}
          <span class="theme-header-custom__cart-count" aria-label="{{ cart.item_count }} items">{{ cart.item_count }}</span>
        {%- endif -%}
      </a>
    </div>
  </div>

  <div class="theme-header-custom__drawer" id="ThemeHeaderDrawer" aria-hidden="true">
    <div class="theme-header-custom__drawer-overlay"></div>
    <div class="theme-header-custom__drawer-content">
      <div class="theme-header-custom__drawer-header">
        <span class="theme-header-custom__drawer-title">Menu</span>
        <button class="theme-header-custom__drawer-close" type="button" aria-label="Close menu">
          <svg viewBox="0 0 24 24" fill="none" aria-hidden="true">
            <path d="M18 6L6 18M6 6l12 12" stroke="currentColor" stroke-width="2" stroke-linecap="round" />
          </svg>
        </button>
      </div>
      <nav class="theme-header-custom__drawer-nav">
        {%- if nav_1_title != blank -%}<a href="{{ nav_1_url }}">{{ nav_1_title }}</a>{%- endif -%}
        {%- if nav_2_title != blank -%}<a href="{{ nav_2_url }}">{{ nav_2_title }}</a>{%- endif -%}
        {%- if nav_3_title != blank -%}<a href="{{ nav_3_url }}">{{ nav_3_title }}</a>{%- endif -%}
        {%- if nav_4_title != blank -%}<a href="{{ nav_4_url }}">{{ nav_4_title }}</a>{%- endif -%}
        {%- if nav_5_title != blank -%}<a href="{{ nav_5_url }}">{{ nav_5_title }}</a>{%- endif -%}
      </nav>
    </div>
  </div>

  <script>
    (function() {
      var header = document.querySelector('.theme-header-custom');
      if (!header) return;

      /* Dynamic header height measurement */
      function setHeaderHeight() {
        var h = header.offsetHeight;
        document.documentElement.style.setProperty('--theme-header-height', h + 'px');
        document.documentElement.style.setProperty('--header-height', h + 'px');
      }
      setHeaderHeight();
      window.addEventListener('resize', setHeaderHeight);
      window.addEventListener('load', setHeaderHeight);

      var menuBtn = header.querySelector('.theme-header-custom__menu-btn');
      var drawer = header.querySelector('.theme-header-custom__drawer');
      var closeBtn = header.querySelector('.theme-header-custom__drawer-close');
      var overlay = header.querySelector('.theme-header-custom__drawer-overlay');

      if (!menuBtn || !drawer) return;

      function openMenu() {
        drawer.classList.add('is-open');
        drawer.setAttribute('aria-hidden', 'false');
        document.body.classList.add('overflow-hidden');
      }

      function closeMenu() {
        drawer.classList.remove('is-open');
        drawer.setAttribute('aria-hidden', 'true');
        document.body.classList.remove('overflow-hidden');
      }

      menuBtn.addEventListener('click', openMenu);
      if (closeBtn) closeBtn.addEventListener('click', closeMenu);
      if (overlay) overlay.addEventListener('click', closeMenu);
    })();
  </script>
</header>

{%- liquid
  assign show_breadcrumbs = true
  if request.page_type == 'index'
    assign show_breadcrumbs = false
  elsif request.page_type == 'search'
    assign show_breadcrumbs = false
  endif
-%}

{%- if show_breadcrumbs -%}
<div class="theme-header-custom__breadcrumbs-wrap">
  <div class="theme-header-custom__breadcrumbs" aria-label="Breadcrumb">
      {%- if request.page_type == 'blog' or request.page_type == 'article' -%}
        <div class="ka-blog-breadcrumb" style="display: flex; align-items: center; gap: 8px; margin: 0; background: transparent; padding: 0; border: 0; box-shadow: none;">
          {%- if request.page_type == 'blog' and current_tags == blank or current_tags == empty or current_tags.size == 0 or current_tags == nil -%}
            <div class="ka-blog-breadcrumb-subnav" style="display: flex; align-items: center; gap: 24px; margin: 0; padding: 0; list-style: none;">
              {%- liquid
                assign subnav_overview = blog.metafields.custom.subnav_overview | default: 'Overview'
                assign subnav_care_paths = blog.metafields.custom.subnav_care_paths | default: 'Care paths'
                assign subnav_topics = blog.metafields.custom.subnav_topics | default: 'Topics'
                assign subnav_latest = blog.metafields.custom.subnav_latest | default: 'Latest articles'
                assign subnav_consult = blog.metafields.custom.subnav_consult | default: 'Consult'
              -%}
              <a class="active" href="#overview">{{ subnav_overview }}</a>
              <a href="#care-paths">{{ subnav_care_paths }}</a>
              <a href="#topics">{{ subnav_topics }}</a>
              <a href="#latest">{{ subnav_latest }}</a>
              <a href="#consult">{{ subnav_consult }}</a>
            </div>
          {%- else -%}
            <a href="{{ blog.url }}">Journal</a>
            <span>&gt;</span>
            {%- if request.page_type == 'blog' and current_tags -%}
              {%- liquid
                assign current_tag = current_tags | first
                assign topic_param = ''
                if canonical_url contains 'topic='
                  assign query_parts = canonical_url | split: 'topic=' | last | split: '&' | first | split: '?' | first | split: '#' | first
                  assign topic_param = query_parts | url_decode | handleize
                endif

                assign topics = blog.metafields.custom.topics.value
                assign topic_title = current_tag
                if topics != blank
                  if topic_param != blank
                    for topic in topics
                      assign temp_handle = topic.system.handle | default: topic.handle | default: topic.title | handleize
                      if temp_handle == topic_param
                        assign topic_title = topic.title
                        break
                      endif
                    endfor
                  endif

                  if topic_title == current_tag
                    for topic in topics
                      if topic.article_filter_tag == current_tag or topic.title == current_tag
                        assign topic_title = topic.title
                        break
                      endif
                    endfor
                  endif
                endif
              -%}
              {%- if current_tags.size > 1 -%}
                {%- liquid
                  assign first_char = topic_title | slice: 0 | upcase
                  assign rest_chars = topic_title | slice: 1, 255
                  assign formatted_topic_title = first_char | append: rest_chars
                -%}
                <a href="{{ blog.url }}/tagged/{{ current_tag | handleize }}{% if topic_param != blank %}?topic={{ topic_param }}{% endif %}">{{ formatted_topic_title }}</a>
                <span>&gt;</span>
                <span class="theme-header-custom__breadcrumb-current">{{ current_tags | last }}</span>
              {%- else -%}
                {%- liquid
                  assign first_char = topic_title | slice: 0 | upcase
                  assign rest_chars = topic_title | slice: 1, 255
                  assign formatted_topic_title = first_char | append: rest_chars
                -%}
                <span class="theme-header-custom__breadcrumb-current">{{ formatted_topic_title }}</span>
              {%- endif -%}
            {%- elsif request.page_type == 'article' -%}
              {%- liquid
                assign topic = article.metafields.custom.topic.value
                assign topic_title = topic.title.value | default: topic.title | default: article.metafields.custom.category_label.value | default: article.metafields.custom.category_label | default: article.tags.first
                assign topic_tag = topic.article_filter_tag.value | default: topic.article_filter_tag | default: topic_title | handleize
              -%}
              {%- if topic_title != blank -%}
                {%- liquid
                  assign first_char = topic_title | slice: 0 | upcase
                  assign rest_chars = topic_title | slice: 1, 255
                  assign formatted_topic_title = first_char | append: rest_chars
                -%}
                <a href="{{ blog.url }}/tagged/{{ topic_tag }}">{{ formatted_topic_title }}</a>
                <span>&gt;</span>
              {%- endif -%}
              <span class="theme-header-custom__breadcrumb-current">{{ article.title }}</span>
            {%- endif -%}
          {%- endif -%}
        </div>
      {%- else -%}
        <a href="{{ routes.root_url }}">Home</a>
        {%- assign breadcrumb_label = '' -%}
        {%- case request.page_type -%}
          {%- when 'product' -%}
            {%- if product != blank -%}
              {%- assign breadcrumb_label = product.title -%}
            {%- else -%}
              {%- assign path_parts = request.path | split: '/' | reverse -%}
              {%- assign prod_handle = path_parts[0] -%}
              {%- assign candidate_product = all_products[prod_handle] -%}
              {%- if candidate_product != blank -%}
                {%- assign breadcrumb_label = candidate_product.title -%}
              {%- endif -%}
            {%- endif -%}
          {%- when 'collection' -%}
            {%- if collection != blank -%}
              {%- assign breadcrumb_label = collection.title -%}
            {%- endif -%}
          {%- when 'page' -%}
            {%- if page != blank and page.title != 'Home' -%}
              {%- assign breadcrumb_label = page.title -%}
            {%- endif -%}
        {%- endcase -%}
        {%- assign custom_breadcrumb_label = section.settings.breadcrumb_current_label | strip -%}
        {%- if request.page_type == 'product'
          and custom_breadcrumb_label != blank
          and custom_breadcrumb_label != 'Home'
          and custom_breadcrumb_label != 'Current Page'
        -%}
          {%- assign breadcrumb_label = custom_breadcrumb_label -%}
        {%- endif -%}
        {%- if breadcrumb_label == blank
          and custom_breadcrumb_label != blank
          and custom_breadcrumb_label != 'Home'
          and custom_breadcrumb_label != 'Current Page'
        -%}
          {%- assign breadcrumb_label = custom_breadcrumb_label -%}
        {%- endif -%}
        {%- if breadcrumb_label == blank or breadcrumb_label == 'Current Page' or breadcrumb_label == 'Home' -%}
          {%- assign breadcrumb_label = product.title | default: page_title -%}
        {%- endif -%}
        {%- if breadcrumb_label != blank -%}
          <span class="theme-header-custom__breadcrumb-sep">&gt;</span>
          <span class="theme-header-custom__breadcrumb-current">{{ breadcrumb_label }}</span>
        {%- endif -%}
      {%- endif -%}
  </div>
</div>
{%- endif -%}



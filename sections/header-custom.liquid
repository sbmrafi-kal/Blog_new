      "default": "Clinics"
    },
    {
      "type": "url",
      "id": "nav_2_url",
      "label": "Nav item 2 link"
    },
    {
      "type": "text",
      "id": "nav_3_title",
      "label": "Nav item 3 label",
      "default": "Resorts"
    },
    {
      "type": "url",
      "id": "nav_3_url",
      "label": "Nav item 3 link"
    },
    {
      "type": "text",
      "id": "nav_4_title",
      "label": "Nav item 4 label",
      "default": "Hospitals"
    },
    {
      "type": "url",
      "id": "nav_4_url",
      "label": "Nav item 4 link"
    },
    {
      "type": "text",
      "id": "nav_5_title",
      "label": "Nav item 5 label",

{{ 'template-collection.css' | asset_url | stylesheet_tag }}
{{ 'component-card.css' | asset_url | stylesheet_tag }}
{{ 'component-price.css' | asset_url | stylesheet_tag }}
{{ 'component-search.css' | asset_url | stylesheet_tag }}
{{ 'ka-blog-redesign.css' | asset_url | stylesheet_tag }}

{%- if section.settings.enable_filtering or section.settings.enable_sorting -%}
  {{ 'component-facets.css' | asset_url | stylesheet_tag }}
  <script src="{{ 'facets.js' | asset_url }}" defer="defer"></script>
{%- endif -%}

{% if section.settings.image_shape == 'blob' %}
  {{ 'mask-blobs.css' | asset_url | stylesheet_tag }}
{%- endif -%}

<script src="{{ 'main-search.js' | asset_url }}" defer="defer"></script>

<style>
  .template-search__header {
    margin-bottom: 3rem;
  }

  .template-search__search {
    margin: 0 auto 3.5rem;
    max-width: 600px !important;
  }

  .template-search__search .search {
    margin-top: 3rem;
  }

  .template-search--empty {
    padding-bottom: 18rem;
  }

  @media screen and (min-width: 750px) {
    .template-search__header {
      margin-bottom: 5rem;
    }
  }

  .search__button .icon {
    height: 1.8rem;
  }

  /* Redesign Search Page Styles */
  .template-search__header h1 {
    font-family: var(--ka-font-heading) !important;
    color: var(--ka-green) !important;
    font-size: clamp(32px, 5vw, 48px) !important;
    font-weight: normal !important;
    text-transform: none !important;
    letter-spacing: 0 !important;
  }

  .template-search__search .search .field {
    border-radius: 99px !important;
    border: 1px solid var(--ka-line) !important;
    background: #FDFFFB !important;
    box-shadow: var(--ka-shadow-soft) !important;
    overflow: hidden;
    height: 56px !important;
    display: flex !important;
    align-items: center !important;
  }

  .template-search__search .search .field:after,
  .template-search__search .search .field:before {
    display: none !important;
  }

  .template-search__search .search .field__input {
    font-family: var(--ka-font-body) !important;
    color: var(--ka-ink) !important;
    font-size: 16px !important;
    padding-left: 24px !important;
    padding-right: 80px !important;
    padding-top: 18px !important;
    padding-bottom: 6px !important;
    height: 100% !important;
    background: transparent !important;
    border: none !important;
    box-shadow: none !important;
    outline: none !important;
    box-sizing: border-box !important;
  }

  .template-search__search .search .field__label {
    left: 24px !important;
    font-family: var(--ka-font-body) !important;
    font-size: 14px !important;
    color: var(--ka-muted) !important;
    top: 50% !important;
    transform: translateY(-50%) !important;
    transition: all 0.2s ease !important;
    pointer-events: none !important;
  }

  .template-search__search .search .field__input:focus ~ .field__label,
  .template-search__search .search .field__input:not(:placeholder-shown) ~ .field__label {
    top: 10px !important;
    transform: none !important;
    font-size: 10px !important;
    opacity: 0.7 !important;
  }

  .template-search__search .search .search__button {
    background: var(--ka-cta-bg) !important;
    color: var(--ka-cta-text) !important;
    border-radius: 0 !important;
    transition: background 0.2s !important;
    height: 100% !important;
    width: 60px !important;
    position: absolute !important;
    right: 0 !important;
    top: 0 !important;
    border: none !important;
    cursor: pointer !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
  }

  .template-search__search .search .search__button:hover {
    background: var(--ka-cta-bg-hover) !important;
  }

  .template-search__search .search .search__button svg {
    width: 20px !important;
    height: 20px !important;
    color: var(--ka-cta-text) !important;
    fill: currentColor !important;
  }

  .template-search__search .search .reset__button {
    right: 60px !important;
    position: absolute !important;
    top: 50% !important;
    transform: translateY(-50%) !important;
    background: transparent !important;
    border: none !important;
    color: var(--ka-muted) !important;
    cursor: pointer !important;
    display: flex !important;
    align-items: center !important;
  }

  .template-search__search .search .reset__button svg circle {
    display: none !important;
  }

  .template-search__search .search .reset__button svg {
    fill: none !important;
    stroke: var(--ka-muted) !important;
    stroke-width: 2px !important;
  }

  /* Mobile search results: 1 card per row, 6 visible */
  @media (max-width: 749px) {
    .template-search .ka-blog-article-grid {
      display: grid !important;
      grid-template-columns: 1fr !important;
      gap: 16px !important;
      overflow-x: hidden !important;
    }
  }
</style>

{%- liquid
  assign sort_by = search.sort_by | default: search.default_sort_by
  assign raw_terms = search.terms
  assign display_terms = raw_terms
  
  if raw_terms contains 'title:('
    assign parts = raw_terms | split: 'title:('
    if parts.size > 1
      assign sub_parts = parts[1] | split: ')'
      assign display_terms = sub_parts[0]
    endif
  endif

  if display_terms == '*' or display_terms == 'author:*' or display_terms == 'tag:*'
    assign display_terms = ''
  endif
  assign terms = display_terms | escape
  assign escaped_raw_terms = raw_terms | escape
  assign search_url = '?q=' | append: escaped_raw_terms | append: '&options%5Bprefix%5D=last&sort_by=' | append: sort_by
-%}

{%- style -%}
  .section-{{ section.id }}-padding {
    padding-top: {{ section.settings.padding_top | times: 0.75 | round: 0 }}px;
    padding-bottom: {{ section.settings.padding_bottom | times: 0.75 | round: 0 }}px;
  }

  @media screen and (min-width: 750px) {
    .section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }
{%- endstyle -%}

{%- liquid
  assign matched_articles = ""
  assign search_term = display_terms | downcase | strip
-%}
{%- paginate blogs['news'].articles by 250 -%}
  {%- if search.performed -%}
    {%- for art in blogs['news'].articles -%}
      {%- assign art_title = art.title | downcase -%}
      {%- assign art_excerpt = art.excerpt | default: art.content | strip_html | downcase -%}
      {%- assign art_dek = art.metafields.custom.dek.value | default: art.metafields.custom.dek | default: '' | downcase -%}
      
      {%- assign match_found = false -%}
      {%- if search_term == blank or search_term == '*' -%}
        {%- assign match_found = true -%}
      {%- elsif art_title contains search_term -%}
        {%- assign match_found = true -%}
      {%- elsif art_excerpt contains search_term -%}
        {%- assign match_found = true -%}
      {%- elsif art_dek contains search_term -%}
        {%- assign match_found = true -%}
      {%- endif -%}
      
      {%- if match_found == false -%}
        {%- for t in art.tags -%}
          {%- assign t_down = t | downcase -%}
          {%- if t_down contains search_term -%}
            {%- assign match_found = true -%}{%- break -%}
          {%- endif -%}
        {%- endfor -%}
      {%- endif -%}
      
      {%- if match_found -%}
        {%- assign matched_articles = matched_articles | append: "," | append: art.handle -%}
      {%- endif -%}
    {%- endfor -%}
  {%- endif -%}
{%- endpaginate -%}

{%- assign matched_handles = matched_articles | split: "," | uniq | compact -%}
{%- assign matched_count = matched_handles.size -%}

{% paginate search.results by 12 %}
  <div class="template-search{% unless search.performed and matched_count > 0 %} template-search--empty{% endunless %} section-{{ section.id }}-padding ka-blog-wrapper">
    <div class="ka-blog-container">
      <div class="template-search__header{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--fade-in{% endif %}" style="text-align: center; margin-bottom: 40px;">
        <h1 style="margin-bottom: 12px; font-family: var(--ka-font-heading); color: var(--ka-green);">
          {%- if search.performed -%}
            {{- 'templates.search.title' | t -}}
          {%- else -%}
            {{- 'general.search.search' | t -}}
          {%- endif -%}
        </h1>
      <div class="template-search__search">
        {%- if settings.predictive_search_enabled -%}
          <predictive-search data-loading-text="{{ 'accessibility.loading' | t }}">
        {%- endif -%}
        <main-search>
          <form action="{{ routes.search_url }}" method="get" role="search" class="search">
            <div class="field">
              <input
                class="search__input field__input"
                id="Search-In-Template"
                type="search"
                name="q"
                value="{{ display_terms | escape }}"
                placeholder="{{ 'general.search.search' | t }}"
                {%- if settings.predictive_search_enabled -%}
                  role="combobox"
                  aria-expanded="false"
                  aria-owns="predictive-search-results"
                  aria-controls="predictive-search-results"
                  aria-haspopup="listbox"
                  aria-autocomplete="list"
                  autocorrect="off"
                  autocomplete="off"
                  autocapitalize="off"
                  spellcheck="false"
                {%- endif -%}
              >
              <label class="field__label" for="Search-In-Template">{{ 'general.search.search' | t }}</label>
              <input name="options[prefix]" type="hidden" value="last">

              {%- if settings.predictive_search_enabled -%}
                <div class="predictive-search predictive-search--search-template" tabindex="-1" data-predictive-search>
                  {%- render 'loading-spinner', class: 'predictive-search__loading-state' -%}
                </div>

                <span class="predictive-search-status visually-hidden" role="status" aria-hidden="true"></span>
              {%- endif -%}

              <button
                type="reset"
                class="reset__button field__button{% if display_terms == blank %} hidden{% endif %}"
                aria-label="{{ 'general.search.reset' | t }}"
              >
                <span class="svg-wrapper">
                  {{- 'icon-reset.svg' | inline_asset_content -}}
                </span>
              </button>
              <button type="submit" class="search__button field__button" aria-label="{{ 'general.search.search' | t }}">
                <span class="svg-wrapper">
                  {{- 'icon-search.svg' | inline_asset_content -}}
                </span>
              </button>
            </div>
          </form>
        </main-search>
        {%- if settings.predictive_search_enabled -%}
          </predictive-search>
        {%- endif -%}
      </div>
      {%- if search.performed -%}
        <p role="status" class="ka-search-count-text">
          {%- if matched_count == 1 -%}
            1 article found
          {%- else -%}
            {{ matched_count }} articles found
          {%- endif -%}
          {%- if display_terms != blank -%}
            &nbsp;for “{{ display_terms }}”
          {%- endif -%}
        </p>
        {%- if matched_count == 0 -%}
          <p role="status" style="text-align: center; margin-top: 16px; font-family: var(--ka-font-body); color: var(--ka-muted);">
            No articles matched your search.
          </p>
        {%- endif -%}
      {%- endif -%}
    </div>
    {%- if search.performed -%}
      {%- if section.settings.enable_sorting
        and section.settings.filter_type == 'vertical'
        and search.filters != empty
      -%}
        <facet-filters-form class="facets facets-vertical-sort page-width small-hide">
          <form class="facets-vertical-form" id="FacetSortForm">
            <div class="facet-filters sorting caption">
              <div class="facet-filters__field">
                <h2 class="facet-filters__label caption-large text-body">
                  <label for="SortBy">{{ 'products.facets.sort_by_label' | t }}</label>
                </h2>
                <div class="select">
                  {%- assign sort_by = search.sort_by | default: search.default_sort_by -%}
                  <select
                    name="sort_by"
                    class="facet-filters__sort select__select caption-large"
                    id="SortBy"
                    aria-describedby="a11y-refresh-page-message"
                  >
                    {%- for option in search.sort_options -%}
                      <option
                        value="{{ option.value | escape }}"
                        {% if option.value == sort_by %}
                          selected="selected"
                        {% endif %}
                      >
                        {{ option.name | escape }}
                      </option>
                    {%- endfor -%}
                  </select>
                  <span class="svg-wrapper">
                    {{- 'icon-caret.svg' | inline_asset_content -}}
                  </span>
                </div>
              </div>
            </div>

            <div class="product-count-vertical light" role="status">
              <h2 class="product-count__text text-body">
                <span id="ProductCountDesktop">
                  {%- if matched_count -%}
                    {%- if display_terms != blank -%}
                      {{ 'templates.search.results_with_count' | t: terms: display_terms, count: matched_count }}
                    {%- else -%}
                      {{ 'templates.search.results_with_count' | t: terms: '', count: matched_count | replace: 'for ""', '' | replace: '""', '' }}
                    {%- endif -%}
                  {%- elsif search.products_count == search.all_products_count -%}
                    {{ 'products.facets.product_count_simple' | t: count: search.products_count }}
                  {%- else -%}
                    {{
                      'products.facets.product_count'
                      | t: product_count: search.products_count, count: search.all_products_count
                    }}
                  {%- endif -%}
                </span>
              </h2>
              {%- render 'loading-spinner' -%}
            </div>
          </form>
        </facet-filters-form>
      {%- endif -%}
      <div
        {% if section.settings.filter_type == 'vertical' %}
          class="facets-vertical page-width"
        {% endif %}
      >
        {%- if search.filters != empty -%}
          {%- if section.settings.enable_filtering or section.settings.enable_sorting -%}
            <aside
              aria-labelledby="verticalTitle"
              class="facets-wrapper{% unless section.settings.enable_filtering %} facets-wrapper--no-filters{% endunless %}{% if section.settings.filter_type != 'vertical' %} page-width{% endif %}"
              id="main-search-filters"
              data-id="{{ section.id }}"
            >
              {% render 'facets',
                results: search,
                enable_filtering: section.settings.enable_filtering,
                enable_sorting: section.settings.enable_sorting,
                filter_type: section.settings.filter_type,
                paginate: paginate
              %}
            </aside>
          {%- endif -%}
        {%- endif -%}
        <div class="product-grid-container" id="ProductGridContainer">
          {%- if search.results.size == 0 and search.filters != empty -%}
            <div
              class="template-search__results collection collection--empty{% if section.settings.filter_type != 'vertical' %} page-width{% endif %}"
              id="product-grid"
              data-id="{{ section.id }}"
            >
              <div class="loading-overlay gradient"></div>
              <div class="title-wrapper center">
                <h2 class="title title--primary">
                  {{ 'sections.collection_template.empty' | t -}}
                  <br>
                  {{
                    'sections.collection_template.use_fewer_filters_html'
                    | t: link: search_url, class: 'underlined-link link'
                  }}
                </h2>
              </div>
            </div>
          {%- else -%}
            <div
              class="template-search__results collection{% if section.settings.filter_type != 'vertical' %} page-width{% endif %}"
              id="product-grid"
              data-id="{{ section.id }}"
            >
              <div class="loading-overlay gradient"></div>

              {%- liquid
                assign has_articles = false
                assign has_others = false
                if matched_count > 0
                  assign has_articles = true
                endif
                for item in search.results
                  if item.object_type != 'article'
                    assign has_others = true
                  endif
                endfor
              -%}

              {%- if has_articles -%}
                {%- liquid
                  assign selected_blog = blogs['news']
                  assign topics = selected_blog.metafields.custom.topics.value
                -%}
                {%- if search_term == blank and topics != blank -%}
                  <nav class="ka-blog-filter-bar" aria-label="Search page filters" style="margin-bottom: 24px;">
                    <a class="active" href="{{ routes.search_url }}?type=article&q=*&options[prefix]=last">All</a>
                    {%- for topic in topics -%}
                      {%- assign topic_title = topic.title.value | default: topic.title -%}
                      {%- assign topic_tag = topic.article_filter_tag.value | default: topic.article_filter_tag | default: topic_title -%}
                      {%- assign topic_tag_mapped = topic_tag | handleize -%}
                      {%- assign raw_tag_handle = topic_tag_mapped -%}
                      {%- if raw_tag_handle contains 'digestion' or raw_tag_handle contains 'digest' or raw_tag_handle contains 'gut' -%}
                        {%- assign topic_tag_mapped = 'digestion' -%}
                      {%- elsif raw_tag_handle contains 'sleep' or raw_tag_handle contains 'stress' or raw_tag_handle contains 'mind' -%}
                        {%- assign topic_tag_mapped = 'sleep' -%}
                      {%- elsif raw_tag_handle contains 'joints' or raw_tag_handle contains 'pain' or raw_tag_handle contains 'bone' -%}
                        {%- assign topic_tag_mapped = 'pain-joints' -%}
                      {%- elsif raw_tag_handle contains 'skin' or raw_tag_handle contains 'hair' or raw_tag_handle contains 'beauty' -%}
                        {%- assign topic_tag_mapped = 'skin-hair' -%}
                      {%- elsif raw_tag_handle contains 'women' -%}
                        {%- assign topic_tag_mapped = 'women-s-health' -%}
                      {%- elsif raw_tag_handle contains 'men' -%}
                        {%- assign topic_tag_mapped = 'men-s-health' -%}
                      {%- elsif raw_tag_handle contains 'kids' or raw_tag_handle contains 'children' -%}
                        {%- assign topic_tag_mapped = 'kids' -%}
                      {%- elsif raw_tag_handle contains 'elder' or raw_tag_handle contains 'old' -%}
                        {%- assign topic_tag_mapped = 'elders' -%}
                      {%- elsif raw_tag_handle contains 'herb' -%}
                        {%- assign topic_tag_mapped = 'herbs' -%}
                      {%- elsif raw_tag_handle contains 'weight' -%}
                        {%- assign topic_tag_mapped = 'weight' -%}
                      {%- elsif raw_tag_handle contains 'immunity' -%}
                        {%- assign topic_tag_mapped = 'immunity' -%}
                      {%- elsif raw_tag_handle contains 'detox' -%}
                        {%- assign topic_tag_mapped = 'detox' -%}
                      {%- endif -%}
                      {%- assign topic_url = selected_blog.url | append: '/tagged/' | append: topic_tag_mapped -%}
                      <a href="{{ topic_url }}">{{ topic_title }}</a>
                    {%- endfor -%}
                  </nav>
                {%- endif -%}

                {%- liquid
                  assign current_page = 1
                  if page_url contains 'page='
                    assign current_page = page_url | split: 'page=' | last | split: '&' | first | plus: 0
                  endif
                  if current_page < 1
                    assign current_page = 1
                  endif
                  
                  assign limit = 12
                  assign offset = current_page | minus: 1 | times: limit
                  assign total_items = matched_handles.size
                  assign total_pages = total_items | plus: limit | minus: 1 | divided_by: limit
                -%}

                <div class="ka-blog-article-grid" style="margin-bottom: 40px;">
                  {%- for handle in matched_handles limit: limit offset: offset -%}
                    {%- assign item = articles[handle] -%}
                    {%- if item != blank -%}
                      {%- render 'ka-blog-card', article: item -%}
                    {%- endif -%}
                  {%- endfor -%}
                </div>

                {%- if total_pages > 1 -%}
                  <nav class="ka-blog-pagination" aria-label="Search results pagination" style="margin-bottom: 40px;">
                    {%- if current_page > 1 -%}
                      <a href="/search?type=article&q={{ escaped_raw_terms }}&options[prefix]=last&page={{ current_page | minus: 1 }}">← Previous</a>
                    {%- endif -%}
                    
                    {%- for page_num in (1..total_pages) -%}
                      {%- if page_num == current_page -%}
                        <span class="current">{{ page_num }}</span>
                      {%- else -%}
                        <a href="/search?type=article&q={{ escaped_raw_terms }}&options[prefix]=last&page={{ page_num }}">{{ page_num }}</a>
                      {%- endif -%}
                    {%- endfor -%}
                    
                    {%- if current_page < total_pages -%}
                      <a href="/search?type=article&q={{ escaped_raw_terms }}&options[prefix]=last&page={{ current_page | plus: 1 }}">Next →</a>
                    {%- endif -%}
                  </nav>
                {%- endif -%}
              {%- endif -%}

              {%- if has_others -%}
                <ul
                  class="grid product-grid grid--{{ section.settings.columns_mobile }}-col-tablet-down grid--{{ section.settings.columns_desktop }}-col-desktop"
                  role="list"
                >
                  {%- assign skip_card_product_styles = false -%}
                  {%- for item in search.results -%}
                    {%- if item.object_type != 'article' -%}
                      {% assign lazy_load = false %}
                      {%- if forloop.index > 2 -%}
                        {%- assign lazy_load = true -%}
                      {%- endif -%}

                      <li
                        class="grid__item{% if settings.animations_reveal_on_scroll %} scroll-trigger animate--slide-in{% endif %}"
                        {% if settings.animations_reveal_on_scroll %}
                          data-cascade
                        {% endif %}
                      >
                        {%- case item.object_type -%}
                          {%- when 'product' -%}
                            {%- capture product_settings -%}{%- if section.settings.product_show_vendor -%}vendor,{%- endif -%}title,price{%- endcapture -%}
                            {% render 'card-product',
                              card_product: item,
                              media_aspect_ratio: section.settings.image_ratio,
                              image_shape: section.settings.image_shape,
                              show_secondary_image: section.settings.show_secondary_image,
                              show_vendor: section.settings.show_vendor,
                              show_rating: section.settings.show_rating,
                              lazy_load: lazy_load,
                              skip_styles: skip_card_product_styles,
                              product_view_context: 'search'
                            %}
                            {%- assign skip_card_product_styles = true -%}
                          {%- when 'page' -%}
                            <div class="article-card-wrapper card-wrapper underline-links-hover">
                              <div
                                class="card card--card card--text ratio color-{{ settings.blog_card_color_scheme }}"
                                style="--ratio-percent: 100%;"
                              >
                                <div class="card__content">
                                  <div class="card__information">
                                    <h3 class="card__heading">
                                      <a href="{{ item.url }}" class="full-unstyled-link">
                                        {{ item.title | truncate: 50 | escape }}
                                      </a>
                                    </h3>
                                  </div>
                                  <div class="card__badge {{ settings.badge_position }}">
                                    <span class="badge color-{{ settings.color_schemes | first }}">
                                      {{- 'templates.search.page' | t -}}
                                    </span>
                                  </div>
                                </div>
                              </div>
                            </div>
                        {%- endcase -%}
                      </li>
                    {%- endif -%}
                  {%- endfor -%}
                </ul>
              {%- endif -%}
              {%- if paginate.pages > 1 -%}
                <div class="ka-blog-pagination">
                  {%- if paginate.previous -%}
                    <a href="{{ paginate.previous.url }}">←</a>
                  {%- endif -%}
                  {%- for part in paginate.parts -%}
                    {%- if part.is_link -%}
                      <a href="{{ part.url }}">{{ part.title }}</a>
                    {%- else -%}
                      {%- if part.title == paginate.current_page -%}
                        <span class="current">{{ part.title }}</span>
                      {%- else -%}
                        <span class="deco">{{ part.title }}</span>
                      {%- endif -%}
                    {%- endif -%}
                  {%- endfor -%}
                  {%- if paginate.next -%}
                    <a href="{{ paginate.next.url }}">→</a>
                  {%- endif -%}
                </div>
              {%- endif -%}
            </div>
          {%- endif -%}
        </div>
      </div>
    {%- endif -%}
    </div>
  </div>
{% endpaginate %}
{% if section.settings.image_shape == 'arch' %}
  {{ 'mask-arch.svg' | inline_asset_content }}
{%- endif -%}

{%- comment -%} ============ CHATBOT ============ {%- endcomment -%}
{%- render 'ka-chatbot' -%}
<script src="{{ 'ka-blog-redesign.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "t:sections.main-search.name",
  "tag": "section",

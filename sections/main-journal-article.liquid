{% comment %}
  main-article-redesign.liquid — Full redesigned article section (meta-driven)
  Renders: hero, two-column layout (content + TOC sidebar), at-a-glance, article body, products, glossary, sources, disclaimer, FAQ, author/reviewer, related articles, share, comments
  Template: article.ayurveda.json
{% endcomment %}

{{ 'ayurhq-journal.css' | asset_url | stylesheet_tag }}
{%- render 'custom-article-font' -%}

{%- liquid
  assign category_label = article.metafields.custom.category_label.value
  assign topic = article.metafields.custom.topic.value
  assign topic_title = topic.title
  assign topic_tag = topic.article_filter_tag | handleize
  assign author_profile = article.metafields.custom.written_by_profile.value
  assign reviewer_profile = article.metafields.custom.reviewed_by_profile.value | default: article.metafields.custom.reviewed_by.value

  assign breadcrumb_home = blog.metafields.custom.breadcrumb_home_label
  assign subnav_overview = blog.metafields.custom.subnav_overview
  assign subnav_care_paths = blog.metafields.custom.subnav_care_paths
  assign subnav_topics = blog.metafields.custom.subnav_topics
  assign subnav_latest = blog.metafields.custom.subnav_latest
  assign subnav_consult = blog.metafields.custom.subnav_consult
  assign toc_heading = blog.metafields.custom.toc_heading
  assign toc_mobile_label = blog.metafields.custom.toc_mobile_label
  assign share_label = blog.metafields.custom.share_label
  assign written_by_label = blog.metafields.custom.written_by_label
  assign reviewed_by_label = blog.metafields.custom.reviewed_by_label
-%}

<div class="ka-blog-wrapper">

  {%- comment -%} ============ BREADCRUMB + ARTICLE HERO ============ {%- endcomment -%}
  <section class="ka-blog-section--tight">
    <div class="ka-blog-container">
      {%- render 'ka-article-hero', article: article, blog: blog -%}
    </div>
  </section>

  {%- comment -%} ============ TWO-COLUMN LAYOUT ============ {%- endcomment -%}
  <section class="ka-blog-section--tight">
    <div class="ka-blog-container ka-article-layout">

      {%- comment -%} ===== MAIN CONTENT COLUMN ===== {%- endcomment -%}
      <article class="ka-article-content">

        {%- comment -%} Why Trust Kerala Ayurveda Card {%- endcomment -%}
        {%- render 'ka-why-trust-card', article: article -%}

        {%- comment -%} Mobile TOC {%- endcomment -%}
        <div class="ka-article-toc-mobile">
          <div class="ka-article-toc-mobile-header">
            <button
              class="ka-article-toc-mobile__toggle"
              aria-expanded="false"
              aria-controls="ka-mobile-toc-content"
            >
              {%- if toc_mobile_label != blank -%}
                <span>{{ toc_mobile_label }}</span>
              {%- endif -%}
              <svg width="16" height="16" viewBox="0 0 16 16" fill="none" aria-hidden="true">
                <path d="M4 6L8 10L12 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </button>
            <button class="ka-article-toc-mobile__help-btn" aria-label="How to use quick scrubber">
              <svg class="ka-align-middle" viewBox="0 0 24 24" width="16" height="16" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                <circle cx="12" cy="12" r="10"></circle>
                <path d="M9.09 9a3 3 0 0 1 5.83 1c0 2-3 3-3 3"></path>
                <line x1="12" y1="17" x2="12.01" y2="17"></line>
              </svg>
              <span>GUIDE</span>
            </button>
          </div>
          <div id="ka-mobile-toc-content" class="ka-article-toc-mobile__content">
            <ul class="ka-article-toc-mobile__list">
              {%- comment -%} Built by JS {%- endcomment -%}
            </ul>
          </div>
        </div>

        {%- comment -%} At a glance {%- endcomment -%}
        {%- render 'ka-article-at-a-glance', article: article -%}

        {%- comment -%} Article body content {%- endcomment -%}
        <div class="ka-article-body prose">
          {%- liquid
            assign body_content = article.metafields.custom.article_body | default: article.content
          -%}
          {{ body_content }}
        </div>

        {%- comment -%} Recommended Products {%- endcomment -%}
        {%- render 'ka-product-recommendations', article: article, blog: blog -%}

        {%- comment -%} Glossary {%- endcomment -%}
        {%- render 'ka-glossary-terms', article: article, blog: blog -%}

        {%- comment -%} Sources {%- endcomment -%}
        {%- render 'ka-article-sources', article: article, blog: blog -%}

        {%- comment -%} Disclaimer {%- endcomment -%}
        {%- render 'ka-article-disclaimer', article: article, blog: blog -%}

        {%- comment -%} FAQ {%- endcomment -%}
        {%- render 'ka-article-faqs', article: article, blog: blog -%}

        {%- comment -%} Author/Reviewer combined card {%- endcomment -%}
        {%- if author_profile != blank or reviewer_profile != blank -%}
          {%- render 'ka-author-reviewer-combined',
            article: article,
            blog: blog,
            author_profile: author_profile,
            reviewer_profile: reviewer_profile,
            written_by_label: written_by_label,
            reviewed_by_label: reviewed_by_label
          -%}
        {%- endif -%}

      </article>

      {%- comment -%} ===== SIDEBAR (Desktop TOC) ===== {%- endcomment -%}
      <aside class="ka-article-sidebar" aria-label="Article table of contents">
        <div class="ka-article-toc-card">
          <h3 class="ka-article-toc-toggle">
            {%- if toc_heading != blank -%}
              <span>{{ toc_heading }}</span>
            {%- endif -%}
            <span class="ka-article-toc-icon" aria-hidden="true">▼</span>
          </h3>
          <ul class="ka-article-sidebar__list">
            {%- comment -%} Built dynamically by ka-blog-redesign.js {%- endcomment -%}
          </ul>
        </div>
      </aside>

    </div>
  </section>

  {%- comment -%} ============ RELATED ARTICLES ============ {%- endcomment -%}
  <div class="ka-blog-container">
    {%- render 'ka-related-articles', article: article, blog: blog -%}
  </div>

  {%- comment -%} ============ COMMENTS ============ {%- endcomment -%}
  <div class="ka-blog-container">
    {%- render 'ka-article-comments', article: article, blog: blog -%}
  </div>

  {%- comment -%} ============ CHATBOT ============ {%- endcomment -%}
  {%- render 'ka-chatbot', blog: blog -%}
</div>

<script src="{{ 'ayurhq-journal.js' | asset_url }}" defer></script>

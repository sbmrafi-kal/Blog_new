{% comment %}
  main-blog-redesign.liquid — Blog landing page section (meta-driven)
  Renders: hero, subnav, care paths, featured article, topics, latest articles, consult CTA
  Template: blog.ayurveda.json
{% endcomment %}

{{ 'ayurhq-journal.css' | asset_url | stylesheet_tag }}
{%- render 'custom-article-font' -%}

{%- liquid
  assign blog_handle = section.settings.blog | default: blog.handle
  if blog_handle == blank
    assign blog_handle = 'news'
  endif
  assign selected_blog = blogs[blog_handle]
-%}

{%- unless current_tags -%}
<div class="ka-blog-wrapper">
  {%- comment -%} ============ SUBNAV ============ {%- endcomment -%}
  {%- liquid
    assign subnav_overview = selected_blog.metafields.custom.subnav_overview
    assign subnav_care_paths = selected_blog.metafields.custom.subnav_care_paths
    assign subnav_topics = selected_blog.metafields.custom.subnav_topics
    assign subnav_latest = selected_blog.metafields.custom.subnav_latest
    assign subnav_consult = selected_blog.metafields.custom.subnav_consult
  -%}
  {%- if subnav_overview != blank or subnav_care_paths != blank or subnav_topics != blank or subnav_latest != blank or subnav_consult != blank -%}
    <div class="ka-blog-subnav-wrap">
      <div class="ka-blog-container">
        <nav class="ka-blog-subnav" aria-label="Blog section navigation">
          {%- if subnav_overview != blank -%}<a class="active" href="#overview">{{ subnav_overview }}</a>{%- endif -%}
          {%- if subnav_care_paths != blank -%}<a href="#care-paths">{{ subnav_care_paths }}</a>{%- endif -%}
          {%- if subnav_topics != blank -%}<a href="#topics">{{ subnav_topics }}</a>{%- endif -%}
          {%- if subnav_latest != blank -%}<a href="#latest">{{ subnav_latest }}</a>{%- endif -%}
          {%- if subnav_consult != blank -%}<a href="#consult">{{ subnav_consult }}</a>{%- endif -%}
        </nav>
      </div>
    </div>
  {%- endif -%}

  <section class="ka-blog-hero" id="overview">
    <div class="ka-blog-container">
      <div class="ka-blog-hero-shell">
        <div class="ka-blog-hero-content">
          {%- liquid
            assign hero_eyebrow = selected_blog.metafields.custom.hero_eyebrow
            assign hero_title = selected_blog.metafields.custom.hero_title
            assign hero_subtitle = selected_blog.metafields.custom.hero_subtitle
            assign hero_image = selected_blog.metafields.custom.hero_image.value | default: selected_blog.metafields.custom.hero_image
            assign hero_cta_1 = selected_blog.metafields.custom.hero_cta_1
            assign hero_cta_2 = selected_blog.metafields.custom.hero_cta_2
          -%}
          {%- if hero_eyebrow != blank -%}
            <p class="ka-blog-eyebrow">{{ hero_eyebrow }}</p>
          {%- endif -%}
          {%- if hero_title != blank -%}
            <h1>
              {%- assign hero_title_stripped = hero_title | strip -%}
              {%- if hero_title_stripped == "Kerala Ayurveda Wellness Journal" -%}
                Kerala Ayurveda<br>Wellness Journal
              {%- else -%}
                {{ hero_title }}
              {%- endif -%}
            </h1>
          {%- endif -%}
          {%- if hero_subtitle != blank -%}
            <p class="ka-blog-lead">{{ hero_subtitle }}</p>
          {%- endif -%}
          
          {%- comment -%} Search Bar {%- endcomment -%}
          <form action="{{ routes.search_url }}" method="get" role="search" class="ka-blog-hero-search">
            <input type="hidden" name="type" value="article">
            <div class="ka-blog-hero-search__field">
              <input
                type="search"
                name="q"
                placeholder="Search articles, herbs, health concerns..."
                aria-label="Search articles"
                required
              >
              <button type="submit" aria-label="Search">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="11" cy="11" r="8"></circle>
                  <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                </svg>
              </button>
            </div>
          </form>

          {%- if hero_cta_1 != blank or hero_cta_2 != blank -%}
            <div class="ka-blog-hero-actions">
              {%- if hero_cta_1 != blank -%}
                <a class="ka-blog-btn" href="#topics">{{ hero_cta_1 }}</a>
              {%- endif -%}
              {%- if hero_cta_2 != blank -%}
                <a class="ka-blog-btn ka-blog-btn--secondary" href="#latest">{{ hero_cta_2 }}</a>
              {%- endif -%}
            </div>
          {%- endif -%}
        </div>
        {%- if hero_image != blank -%}
          <div class="ka-blog-hero-image-wrap">
            <img src="{{ hero_image | image_url: width: 800 }}" alt="{{ hero_title | escape }}" loading="eager" fetchpriority="high" width="800" height="500">
          </div>
        {%- endif -%}
      </div>
    </div>
  </section>

  {%- comment -%} ============ CARE PATHS ============ {%- endcomment -%}
  {%- liquid
    assign care_paths_eyebrow = selected_blog.metafields.custom.care_paths_eyebrow
    assign care_paths_eyebrow_hindi = selected_blog.metafields.custom.care_paths_eyebrow_hindi
    assign care_paths_title = selected_blog.metafields.custom.care_paths_title
    assign care_paths_intro_title = selected_blog.metafields.custom.care_paths_intro_title
    assign care_paths_intro_text = selected_blog.metafields.custom.care_paths_intro_text
    assign care_paths = selected_blog.metafields.custom.care_paths.value
  -%}
  {%- if care_paths != blank and care_paths.size > 0 -%}
    <section class="ka-blog-section" id="care-paths">
      <div class="ka-blog-container">
        <div class="ka-blog-section-head">
          <div>
            <p class="ka-blog-eyebrow">
              {{ care_paths_eyebrow }}
              {%- if care_paths_eyebrow_hindi != blank -%}
                <span class="ka-hindi"> · {{ care_paths_eyebrow_hindi }}</span>
              {%- endif -%}
            </p>
            {%- if care_paths_title != blank -%}
              <h2>{{ care_paths_title }}</h2>
            {%- endif -%}
          </div>
        </div>

        <div class="ka-blog-care-panel">
          {%- if care_paths_intro_title != blank or care_paths_intro_text != blank -%}
            <div class="ka-blog-care-intro">
              {%- if care_paths_intro_title != blank -%}
                <h3>{{ care_paths_intro_title }}</h3>
              {%- endif -%}
              {%- if care_paths_intro_text != blank -%}
                <p class="ka-blog-lead">{{ care_paths_intro_text }}</p>
              {%- endif -%}
            </div>
          {%- endif -%}
          <div class="ka-blog-path-list">
            {%- for care_path in care_paths -%}
              {%- render 'ka-care-path-card', care_path: care_path, blog: selected_blog -%}
            {%- endfor -%}
          </div>
        </div>
      </div>
    </section>
  {%- endif -%}

  {%- comment -%} ============ FEATURED ARTICLE ============ {%- endcomment -%}
  {%- liquid
    assign featured_article = selected_blog.metafields.custom.featured_article.value | default: selected_blog.metafields.custom.featured_article
    assign featured_eyebrow = selected_blog.metafields.custom.featured_eyebrow
    assign featured_title = selected_blog.metafields.custom.featured_title
  -%}
  {%- if featured_article -%}
    <section class="ka-blog-section--tight">
      <div class="ka-blog-container">
        <div class="ka-blog-section-head">
          <div>
            {%- if featured_eyebrow != blank -%}
              <p class="ka-blog-eyebrow">{{ featured_eyebrow }}</p>
            {%- endif -%}
            {%- if featured_title != blank -%}
              <h2>{{ featured_title }}</h2>
            {%- endif -%}
          </div>
        </div>
        {%- render 'ka-featured-article-card', article: featured_article -%}
      </div>
    </section>
  {%- endif -%}

  {%- comment -%} ============ TOPICS GRID ============ {%- endcomment -%}
  {%- liquid
    assign topics_eyebrow = selected_blog.metafields.custom.topics_eyebrow
    assign topics_eyebrow_hindi = selected_blog.metafields.custom.topics_eyebrow_hindi
    assign topics_title = selected_blog.metafields.custom.topics_title
    assign topics = selected_blog.metafields.custom.topics.value
    assign batch_size = 8
  -%}
  {%- if topics != blank and topics.size > 0 -%}
    <section class="ka-blog-section" id="topics">
      <div class="ka-blog-container">
        <div class="ka-blog-topic-carousel-outer">
          <div class="ka-blog-topic-sticky-wrap">
            <div class="ka-blog-section-head ka-section-head--tight">
              <div>
                <p class="ka-blog-eyebrow">
                  {{ topics_eyebrow }}
                  {%- if topics_eyebrow_hindi != blank -%}
                    <span class="ka-hindi"> · {{ topics_eyebrow_hindi }}</span>
                  {%- endif -%}
                </p>
                {%- if topics_title != blank -%}
                  <h2>{{ topics_title }}</h2>
                {%- endif -%}
              </div>
            </div>
            <div class="ka-blog-topic-carousel-container">
              <div class="ka-blog-topic-carousel-track">
                {%- for topic in topics -%}
                  {%- assign modulo = forloop.index0 | modulo: batch_size -%}
                  {%- if modulo == 0 -%}
                    {%- assign deck_index = forloop.index0 | divided_by: batch_size -%}
                    {%- if forloop.index0 > 0 -%}
                      </div>
                    {%- endif -%}
                    <div class="ka-blog-topic-deck{% if deck_index == 0 %} active{% endif %}" data-deck-index="{{ deck_index }}">
                  {%- endif -%}
                  {%- render 'ka-topic-card', topic: topic, blog: selected_blog, index: forloop.index0 -%}
                  {%- if forloop.last -%}
                    </div>
                  {%- endif -%}
                {%- endfor -%}
              </div>
            </div>
            {%- assign total_decks = topics.size | plus: batch_size | minus: 1 | divided_by: batch_size -%}
            {%- if total_decks > 1 -%}
              <div class="ka-blog-topic-nav" aria-label="Topics carousel navigation">
                <button class="ka-blog-topic-arrow ka-blog-topic-arrow--prev" aria-label="Previous topics" disabled>
                  <svg viewBox="0 0 24 24"><polyline points="15 18 9 12 15 6"></polyline></svg>
                </button>
                <div class="ka-blog-topic-dots" aria-hidden="true">
                  {%- for i in (1..total_decks) -%}
                    {%- assign zero_index = forloop.index0 -%}
                    <span class="ka-blog-topic-dot{% if zero_index == 0 %} active{% endif %}" data-index="{{ zero_index }}"></span>
                  {%- endfor -%}
                </div>
                <button class="ka-blog-topic-arrow ka-blog-topic-arrow--next" aria-label="Next topics">
                  <svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6"></polyline></svg>
                </button>
              </div>
            {%- endif -%}
          </div>
        </div>
      </div>
    </section>
  {%- endif -%}

  {%- comment -%} ============ LATEST ARTICLES ============ {%- endcomment -%}
  {%- liquid
    assign latest_title = selected_blog.metafields.custom.latest_title
  -%}
  <section class="ka-blog-section" id="latest">
    <div class="ka-blog-container">
      <div class="ka-blog-section-head">
        <div>
          <p class="ka-blog-eyebrow">{{ selected_blog.articles_count }} articles</p>
          {%- if latest_title != blank -%}
            <h2>{{ latest_title }}</h2>
          {%- endif -%}
        </div>
        {%- if selected_blog.articles_count > 6 -%}
          <a class="ka-blog-btn ka-blog-btn--outline" href="{{ routes.search_url }}?type=article&q=*&options[prefix]=last">View all</a>
        {%- endif -%}
      </div>

      {%- paginate blogs[blog_handle].articles by 9 -%}
        <div class="ka-blog-article-grid">
          {%- for article in blogs[blog_handle].articles -%}
            {%- render 'ka-blog-card', article: article -%}
          {%- endfor -%}
        </div>

        {%- if paginate.pages > 1 -%}
          <nav class="ka-blog-pagination" aria-label="Blog pagination">
            {%- if paginate.previous -%}
              <a href="{{ paginate.previous.url }}#latest">← Previous</a>
            {%- endif -%}
            {%- for part in paginate.parts -%}
              {%- if part.is_link -%}
                <a href="{{ part.url }}#latest">{{ part.title }}</a>
              {%- else -%}
                {%- if part.title == paginate.current_page -%}
                  <span class="current">{{ part.title }}</span>
                {%- else -%}
                  <span class="deco">{{ part.title }}</span>
                {%- endif -%}
              {%- endif -%}
            {%- endfor -%}
            {%- if paginate.next -%}
              <a href="{{ paginate.next.url }}#latest">Next →</a>
            {%- endif -%}
          </nav>
        {%- endif -%}
      {%- endpaginate -%}
    </div>
  </section>

  {%- comment -%} ============ CONSULT CTA ============ {%- endcomment -%}
  {%- render 'ka-consult-cta', blog: selected_blog, section: section -%}

  {%- render 'ka-chatbot', blog: selected_blog -%}

</div>

<script src="{{ 'ayurhq-journal.js' | asset_url }}" defer></script>
{%- endunless -%}

{% schema %}
{
  "name": "Blog — Redesign",
  "tag": "section",
  "class": "ka-blog-main-section",
  "settings": [
    {
      "type": "blog",
      "id": "blog",
      "label": "Select Blog",
      "info": "Choose the blog to render. Fallbacks to the current template blog if empty."
    },
    {
      "type": "header",
      "content": "Hero"
    },
    {
      "type": "text",
      "id": "hero_eyebrow",
      "label": "Hero eyebrow",
      "default": "AYURVEDA LIBRARY"
    },
    {
      "type": "text",
      "id": "hero_title",
      "label": "Hero title",
      "default": "Kerala Ayurveda Wellness Journal"
    },
    {
      "type": "textarea",
      "id": "hero_subtitle",
      "label": "Hero subtitle",
      "default": "Classical Ayurvedic wisdom for herbs, digestion, immunity, skin, hair, stress, sleep, detox, and everyday wellness."
    },
    {
      "type": "header",
      "content": "Consultation CTA"
    },
    {
      "type": "text",
      "id": "consult_title",
      "label": "Consult title",
      "default": "Need help choosing the right Ayurvedic support?"
    },
    {
      "type": "textarea",
      "id": "consult_text",
      "label": "Consult description"
    },
    {
      "type": "text",
      "id": "consult_button",
      "label": "Consult button label",
      "default": "WhatsApp consults opening soon"
    },
    {
      "type": "url",
      "id": "consult_url",
      "label": "Consult button link"
    },
    {
      "type": "header",
      "content": "Disclaimer"
    },
    {
      "type": "textarea",
      "id": "default_disclaimer",
      "label": "Default health disclaimer",
      "default": "This content is for informational and educational purposes only. It is not intended as medical advice and should not replace consultation with a qualified healthcare professional."
    }
  ],
  "blocks": [
    {
      "type": "care_path",
      "name": "Care Path",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Digestion & gut"
        },
        {
          "type": "textarea",
          "id": "subtitle",
          "label": "Subtitle"
        },
        {
          "type": "text",
          "id": "tag",
          "label": "Blog tag filter",
          "info": "The Shopify blog tag to filter articles"
        },
        {
          "type": "text",
          "id": "cta_label",
          "label": "CTA label",
          "default": "Explore"
        }
      ]
    }
  ]
}
{% endschema %}

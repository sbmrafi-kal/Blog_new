{% comment %}
  main-blog-redesign.liquid — Blog landing page section
  Renders: hero, subnav, care paths, featured article, topics, latest articles, consult CTA
  Template: blog.ayurveda.json
{% endcomment %}

{{ 'ka-blog-redesign.css' | asset_url | stylesheet_tag }}
{%- render 'custom-article-font' -%}

{%- liquid
  assign blog_handle = section.settings.blog | default: blog.handle
  if blog_handle == blank
    assign blog_handle = 'news'
  endif
  assign selected_blog = blogs[blog_handle]
-%}

<div class="ka-blog-wrapper">

  {%- comment -%} ============ SUBNAV ============ {%- endcomment -%}
  <div class="ka-blog-subnav-wrap">
    <div class="ka-blog-container">
      <nav class="ka-blog-subnav" aria-label="Blog section navigation">
        <a class="active" href="#overview">Overview</a>
        <a href="#care-paths">Care paths</a>
        <a href="#topics">Topics</a>
        <a href="#latest">Latest articles</a>
        <a href="#consult">Consult</a>
      </nav>
    </div>
  </div>

  {%- comment -%} ============ HERO ============ {%- endcomment -%}
  <section class="ka-blog-hero" id="overview">
    <div class="ka-blog-container">
      <div class="ka-blog-hero-shell">
        <div class="ka-blog-hero-content">
          {%- liquid
            assign hero_eyebrow = selected_blog.metafields.custom.hero_eyebrow | default: section.settings.hero_eyebrow | default: 'AYURVEDA LIBRARY'
            assign hero_title = selected_blog.metafields.custom.hero_title | default: section.settings.hero_title | default: selected_blog.title
            assign hero_subtitle = selected_blog.metafields.custom.hero_subtitle | default: section.settings.hero_subtitle | default: 'Classical Ayurvedic wisdom for herbs, digestion, immunity, skin, hair, stress, sleep, detox, and everyday wellness.'
          -%}
          <p class="ka-blog-eyebrow">{{ hero_eyebrow }}</p>
          <h1>{{ hero_title }}</h1>
          <p class="ka-blog-lead">{{ hero_subtitle }}</p>
          <div class="ka-blog-hero-actions">
            <a class="ka-blog-btn" href="#topics">Explore topics</a>
            <a class="ka-blog-btn ka-blog-btn--secondary" href="#latest">Latest articles</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  {%- comment -%} ============ CARE PATHS ============ {%- endcomment -%}
  <section class="ka-blog-section" id="care-paths">
    <div class="ka-blog-container">
      <div class="ka-blog-section-head">
        <div>
          <p class="ka-blog-eyebrow">Start here <span class="ka-hindi">· शुरू करें</span></p>
          <h2>Care paths</h2>
        </div>
      </div>

      <div class="ka-blog-care-panel">
        <div class="ka-blog-care-intro">
          <h3>Choose a health concern</h3>
          <p class="ka-blog-lead">Each path groups Ayurvedic articles around a specific area of wellness, so you can read what matters to you.</p>
        </div>
        <div class="ka-blog-path-list">
          {%- liquid
            assign care_paths = selected_blog.metafields.custom.care_paths.value
          -%}
          {%- if care_paths != blank and care_paths.size > 0 -%}
            {%- for care_path in care_paths -%}
              {%- render 'ka-care-path-card', care_path: care_path, blog: selected_blog -%}
            {%- endfor -%}
          {%- else -%}
            {%- comment -%} Fallback: render from section blocks {%- endcomment -%}
            {%- for block in section.blocks -%}
              {%- if block.type == 'care_path' -%}
                <a class="ka-blog-path-row" href="{{ selected_blog.url }}/tagged/{{ block.settings.tag | handleize }}" {{ block.shopify_attributes }}>
                  <div>
                    <h3>{{ block.settings.title }}</h3>
                    {%- if block.settings.subtitle != blank -%}
                      <p class="ka-blog-muted">{{ block.settings.subtitle }}</p>
                    {%- endif -%}
                  </div>
                  <div class="ka-blog-path-tags">
                    <span class="ka-blog-path-cta">{{ block.settings.cta_label | default: 'Explore' }} →</span>
                  </div>
                </a>
              {%- endif -%}
            {%- endfor -%}
          {%- endif -%}
        </div>
      </div>
    </div>
  </section>

  {%- comment -%} ============ FEATURED ARTICLE ============ {%- endcomment -%}
  {%- liquid
    assign featured_article = selected_blog.metafields.custom.featured_article
    if featured_article == blank
      assign featured_article = selected_blog.articles.first
    endif
  -%}
  {%- if featured_article -%}
    <section class="ka-blog-section--tight">
      <div class="ka-blog-container">
        <div class="ka-blog-section-head">
          <div>
            <p class="ka-blog-eyebrow">Featured</p>
            <h2>Editor's pick</h2>
          </div>
        </div>
        {%- render 'ka-featured-article-card', article: featured_article -%}
      </div>
    </section>
  {%- endif -%}

  {%- comment -%} ============ TOPICS GRID ============ {%- endcomment -%}
  <section class="ka-blog-section" id="topics">
    <div class="ka-blog-container">
      <div class="ka-blog-section-head">
        <div>
          <p class="ka-blog-eyebrow">Browse by topic <span class="ka-hindi">· विषय</span></p>
          <h2>Topics</h2>
        </div>
      </div>

      <div class="ka-blog-topic-grid">
        {%- liquid
          assign topics = selected_blog.metafields.custom.topics.value
        -%}
        {%- if topics != blank and topics.size > 0 -%}
          {%- for topic in topics -%}
            {%- render 'ka-topic-card', topic: topic, blog: selected_blog -%}
          {%- endfor -%}
        {%- else -%}
          {%- comment -%} Fallback: render from blog tags {%- endcomment -%}
          {%- for tag in selected_blog.all_tags limit: 8 -%}
            <a class="ka-blog-image-card" href="{{ selected_blog.url }}/tagged/{{ tag | handleize }}">
              <div class="ka-blog-image-card__overlay" aria-hidden="true"></div>
              <div class="ka-blog-image-card__content">
                <h3>{{ tag }}</h3>
                <span class="ka-blog-read-more">Explore topic</span>
              </div>
            </a>
          {%- endfor -%}
        {%- endif -%}
      </div>
    </div>
  </section>

  {%- comment -%} ============ LATEST ARTICLES ============ {%- endcomment -%}
  <section class="ka-blog-section" id="latest">
    <div class="ka-blog-container">
      <div class="ka-blog-section-head">
        <div>
          <p class="ka-blog-eyebrow">{{ selected_blog.articles_count }} articles</p>
          <h2>Latest from the journal</h2>
        </div>
        {%- if selected_blog.articles_count > 6 -%}
          <a class="ka-blog-btn ka-blog-btn--outline" href="#latest">View all</a>
        {%- endif -%}
      </div>

      {%- paginate blogs[blog_handle].articles by 9 -%}
        <div class="ka-blog-article-grid">
          {%- for article in blogs[blog_handle].articles -%}
            {%- render 'ka-blog-card', article: article -%}
          {%- endfor -%}
        </div>

        {%- if paginate.pages > 1 -%}
          <nav class="ka-blog-pagination" aria-label="Blog pagination">
            {%- if paginate.previous -%}
              <a href="{{ paginate.previous.url }}">← Previous</a>
            {%- endif -%}
            {%- for part in paginate.parts -%}
              {%- if part.is_link -%}
                <a href="{{ part.url }}">{{ part.title }}</a>
              {%- else -%}
                <span class="current">{{ part.title }}</span>
              {%- endif -%}
            {%- endfor -%}
            {%- if paginate.next -%}
              <a href="{{ paginate.next.url }}">Next →</a>
            {%- endif -%}
          </nav>
        {%- endif -%}
      {%- endpaginate -%}
    </div>
  </section>

  {%- comment -%} ============ CONSULT CTA ============ {%- endcomment -%}
  {%- render 'ka-consult-cta', blog: selected_blog, section: section -%}

  {%- comment -%} ============ FLOATING CTA ============ {%- endcomment -%}
  <a class="ka-blog-floating-cta" href="#consult">Ask an Ayurvedic doctor</a>

</div>

<script src="{{ 'ka-blog-redesign.js' | asset_url }}" defer></script>

{% schema %}
{
  "name": "Blog — Redesign",
  "tag": "section",
  "class": "ka-blog-main-section",
  "settings": [
    {
      "type": "blog",
      "id": "blog",
      "label": "Select Blog",
      "info": "Choose the blog to render. Fallbacks to the current template blog if empty."
    },
    {
      "type": "header",
      "content": "Hero"
    },
    {
      "type": "text",
      "id": "hero_eyebrow",
      "label": "Hero eyebrow",
      "default": "AYURVEDA LIBRARY"
    },
    {
      "type": "text",
      "id": "hero_title",
      "label": "Hero title",
      "default": "Kerala Ayurveda Wellness Journal"
    },
    {
      "type": "textarea",
      "id": "hero_subtitle",
      "label": "Hero subtitle",
      "default": "Classical Ayurvedic wisdom for herbs, digestion, immunity, skin, hair, stress, sleep, detox, and everyday wellness."
    },
    {
      "type": "header",
      "content": "Consultation CTA"
    },
    {
      "type": "text",
      "id": "consult_title",
      "label": "Consult title",
      "default": "Need help choosing the right Ayurvedic support?"
    },
    {
      "type": "textarea",
      "id": "consult_text",
      "label": "Consult description"
    },
    {
      "type": "text",
      "id": "consult_button",
      "label": "Consult button label",
      "default": "WhatsApp consults opening soon"
    },
    {
      "type": "url",
      "id": "consult_url",
      "label": "Consult button link"
    },
    {
      "type": "header",
      "content": "Disclaimer"
    },
    {
      "type": "textarea",
      "id": "default_disclaimer",
      "label": "Default health disclaimer",
      "default": "This content is for informational and educational purposes only. It is not intended as medical advice and should not replace consultation with a qualified healthcare professional."
    }
  ],
  "blocks": [
    {
      "type": "care_path",
      "name": "Care Path",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Digestion & gut"
        },
        {
          "type": "textarea",
          "id": "subtitle",
          "label": "Subtitle"
        },
        {
          "type": "text",
          "id": "tag",
          "label": "Blog tag filter",
          "info": "The Shopify blog tag to filter articles"
        },
        {
          "type": "text",
          "id": "cta_label",
          "label": "CTA label",
          "default": "Explore"
        }
      ]
    }
  ],
  "templates": ["blog", "index"]
}
{% endschema %}

{% comment %}
  main-blog-redesign.liquid — Blog landing page section
  Renders: hero, subnav, care paths, featured article, topics, latest articles, consult CTA
  Template: blog.ayurveda.json
{% endcomment %}

{{ 'ka-blog-redesign.css' | asset_url | stylesheet_tag }}
{%- render 'custom-article-font' -%}

{%- liquid
  assign blog_handle = section.settings.blog | default: blog.handle
  if blog_handle == blank
    assign blog_handle = 'news'
  endif
  assign selected_blog = blogs[blog_handle]
-%}

{%- unless current_tags -%}
<div class="ka-blog-wrapper">
  {%- comment -%} ============ SUBNAV ============ {%- endcomment -%}
  <div class="ka-blog-subnav-wrap">
    <div class="ka-blog-container">
      <nav class="ka-blog-subnav" aria-label="Blog section navigation">
        {%- liquid
          assign subnav_overview = selected_blog.metafields.custom.subnav_overview | default: 'Overview'
          assign subnav_care_paths = selected_blog.metafields.custom.subnav_care_paths | default: 'Care paths'
          assign subnav_topics = selected_blog.metafields.custom.subnav_topics | default: 'Topics'
          assign subnav_latest = selected_blog.metafields.custom.subnav_latest | default: 'Latest articles'
          assign subnav_consult = selected_blog.metafields.custom.subnav_consult | default: 'Consult'
        -%}
        <a class="active" href="#overview">{{ subnav_overview }}</a>
        <a href="#care-paths">{{ subnav_care_paths }}</a>
        <a href="#topics">{{ subnav_topics }}</a>
        <a href="#latest">{{ subnav_latest }}</a>
        <a href="#consult">{{ subnav_consult }}</a>
      </nav>
    </div>
  </div>

  <section class="ka-blog-hero" id="overview">
    <div class="ka-blog-container">
      <div class="ka-blog-hero-shell">
        <div class="ka-blog-hero-content">
          {%- liquid
            assign hero_eyebrow = selected_blog.metafields.custom.hero_eyebrow | default: section.settings.hero_eyebrow | default: 'AYURVEDA LIBRARY'
            assign hero_title = selected_blog.metafields.custom.hero_title | default: section.settings.hero_title | default: selected_blog.title
            assign hero_subtitle = selected_blog.metafields.custom.hero_subtitle | default: section.settings.hero_subtitle | default: 'Classical Ayurvedic wisdom for herbs, digestion, immunity, skin, hair, stress, sleep, detox, and everyday wellness.'
            assign hero_image = selected_blog.metafields.custom.hero_image.value | default: selected_blog.metafields.custom.hero_image
          -%}
          <p class="ka-blog-eyebrow">{{ hero_eyebrow }}</p>
          <h1>
            {%- assign hero_title_stripped = hero_title | strip -%}
            {%- if hero_title_stripped == "Kerala Ayurveda Wellness Journal" -%}
              Kerala Ayurveda<br>Wellness Journal
            {%- else -%}
              {{ hero_title }}
            {%- endif -%}
          </h1>
          <p class="ka-blog-lead">{{ hero_subtitle }}</p>
          
          {%- comment -%} Search Bar {%- endcomment -%}
          <form action="{{ routes.search_url }}" method="get" role="search" class="ka-blog-hero-search">
            <input type="hidden" name="type" value="article">
            <div class="ka-blog-hero-search__field">
              <input
                type="search"
                name="q"
                placeholder="Search articles, herbs, health concerns..."
                aria-label="Search articles"
                required
              >
              <button type="submit" aria-label="Search">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <circle cx="11" cy="11" r="8"></circle>
                  <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
                </svg>
              </button>
            </div>
          </form>

          <div class="ka-blog-hero-actions">
            <a class="ka-blog-btn" href="#topics">{{ selected_blog.metafields.custom.hero_cta_1 | default: 'Explore topics' }}</a>
            <a class="ka-blog-btn ka-blog-btn--secondary" href="#latest">{{ selected_blog.metafields.custom.hero_cta_2 | default: 'Latest articles' }}</a>
          </div>
        </div>
        <div class="ka-blog-hero-image-wrap">
          {%- if hero_image != blank -%}
            <img src="{{ hero_image | image_url: width: 800 }}" alt="{{ hero_title | escape }}">
          {%- else -%}
            <img src="https://images.unsplash.com/photo-1540555700478-4be289fbecef?auto=format&fit=crop&q=80&w=800" alt="{{ hero_title | escape }}">
          {%- endif -%}
        </div>
      </div>
    </div>
  </section>

  {%- comment -%} ============ CARE PATHS ============ {%- endcomment -%}
  <section class="ka-blog-section" id="care-paths">
    <div class="ka-blog-container">
      <div class="ka-blog-section-head">
        <div>
          <p class="ka-blog-eyebrow">{{ selected_blog.metafields.custom.care_paths_eyebrow | default: 'Start here' }} <span class="ka-hindi">{{ selected_blog.metafields.custom.care_paths_eyebrow_hindi | default: '· शुरू करें' }}</span></p>
          <h2>{{ selected_blog.metafields.custom.care_paths_title | default: 'Care paths' }}</h2>
        </div>
      </div>

      <div class="ka-blog-care-panel">
        <div class="ka-blog-care-intro">
          <h3>{{ selected_blog.metafields.custom.care_paths_intro_title | default: 'Choose a health concern' }}</h3>
          <p class="ka-blog-lead">{{ selected_blog.metafields.custom.care_paths_intro_text | default: 'Each path groups Ayurvedic articles around a specific area of wellness, so you can read what matters to you.' }}</p>
        </div>
        <div class="ka-blog-path-list">
          {%- liquid
            assign care_paths = selected_blog.metafields.custom.care_paths.value
          -%}
          {%- if care_paths != blank and care_paths.size > 0 -%}
            {%- for care_path in care_paths -%}
              {%- render 'ka-care-path-card', care_path: care_path, blog: selected_blog -%}
            {%- endfor -%}
          {%- endif -%}
        </div>
      </div>
    </div>
  </section>

  {%- comment -%} ============ FEATURED ARTICLE ============ {%- endcomment -%}
  {%- liquid
    assign featured_article = selected_blog.metafields.custom.featured_article.value | default: selected_blog.metafields.custom.featured_article
  -%}
  {%- if featured_article -%}
    <section class="ka-blog-section--tight">
      <div class="ka-blog-container">
        <div class="ka-blog-section-head">
          <div>
            <p class="ka-blog-eyebrow">{{ selected_blog.metafields.custom.featured_eyebrow | default: 'Featured' }}</p>
            <h2>{{ selected_blog.metafields.custom.featured_title | default: "Editor's pick" }}</h2>
          </div>
        </div>
        {%- render 'ka-featured-article-card', article: featured_article -%}
      </div>
    </section>
  {%- endif -%}

  {%- comment -%} ============ TOPICS GRID ============ {%- endcomment -%}
  <section class="ka-blog-section" id="topics">
    <div class="ka-blog-container">
      <div class="ka-blog-topic-carousel-outer">
        <div class="ka-blog-topic-sticky-wrap">
          <div class="ka-blog-section-head" style="margin-bottom: 24px;">
            <div>
              <p class="ka-blog-eyebrow">{{ selected_blog.metafields.custom.topics_eyebrow | default: 'Browse by topic' }} <span class="ka-hindi">{{ selected_blog.metafields.custom.topics_eyebrow_hindi | default: '· विषय' }}</span></p>
              <h2>{{ selected_blog.metafields.custom.topics_title | default: 'Topics' }}</h2>
            </div>
          </div>
          <div class="ka-blog-topic-carousel-container">
            <div class="ka-blog-topic-carousel-track">
              {%- liquid
                assign topics = selected_blog.metafields.custom.topics.value
                assign batch_size = 8
              -%}
              {%- if topics != blank and topics.size > 0 -%}
                {%- for topic in topics -%}
                  {%- assign modulo = forloop.index0 | modulo: batch_size -%}
                  {%- if modulo == 0 -%}
                    {%- assign deck_index = forloop.index0 | divided_by: batch_size -%}
                    {%- if forloop.index0 > 0 -%}
                      </div>
                    {%- endif -%}
                    <div class="ka-blog-topic-deck{% if deck_index == 0 %} active{% endif %}" data-deck-index="{{ deck_index }}">
                  {%- endif -%}
                  {%- render 'ka-topic-card', topic: topic, blog: selected_blog, index: forloop.index0 -%}
                  {%- if forloop.last -%}
                    </div>
                  {%- endif -%}
                {%- endfor -%}
              {%- endif -%}
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {%- comment -%} ============ LATEST ARTICLES ============ {%- endcomment -%}
  <section class="ka-blog-section" id="latest">
    <div class="ka-blog-container">
      <div class="ka-blog-section-head">
        <div>
          <p class="ka-blog-eyebrow">{{ selected_blog.articles_count }} articles</p>
          <h2>{{ selected_blog.metafields.custom.latest_title | default: 'Latest from the journal' }}</h2>
        </div>
        {%- if selected_blog.articles_count > 6 -%}
          <a class="ka-blog-btn ka-blog-btn--outline" href="{{ routes.search_url }}?type=article&q=*&options[prefix]=last">View all</a>
        {%- endif -%}
      </div>

      {%- paginate blogs[blog_handle].articles by 9 -%}
        <div class="ka-blog-article-grid">
          {%- for article in blogs[blog_handle].articles -%}
            {%- render 'ka-blog-card', article: article -%}
          {%- endfor -%}
        </div>

        {%- if paginate.pages > 1 -%}
          <nav class="ka-blog-pagination" aria-label="Blog pagination">
            {%- if paginate.previous -%}
              <a href="{{ paginate.previous.url }}#latest">← Previous</a>
            {%- endif -%}
            {%- for part in paginate.parts -%}
              {%- if part.is_link -%}
                <a href="{{ part.url }}#latest">{{ part.title }}</a>
              {%- else -%}
                <span class="current">{{ part.title }}</span>
              {%- endif -%}
            {%- endfor -%}
            {%- if paginate.next -%}
              <a href="{{ paginate.next.url }}#latest">Next →</a>
            {%- endif -%}
          </nav>
        {%- endif -%}
      {%- endpaginate -%}
    </div>
  </section>

  {%- comment -%} ============ CONSULT CTA ============ {%- endcomment -%}
  {%- render 'ka-consult-cta', blog: selected_blog, section: section -%}

  {%- render 'ka-chatbot', blog: selected_blog -%}

</div>

<script src="{{ 'ka-blog-redesign.js' | asset_url }}" defer></script>
{%- endunless -%}

{% schema %}
{
  "name": "Blog — Redesign",
  "tag": "section",
  "class": "ka-blog-main-section",
  "settings": [
    {
      "type": "blog",
      "id": "blog",
      "label": "Select Blog",
      "info": "Choose the blog to render. Fallbacks to the current template blog if empty."
    },
    {
      "type": "header",
      "content": "Hero"
    },
    {
      "type": "text",
      "id": "hero_eyebrow",
      "label": "Hero eyebrow",
      "default": "AYURVEDA LIBRARY"
    },
    {
      "type": "text",
      "id": "hero_title",
      "label": "Hero title",
      "default": "Kerala Ayurveda Wellness Journal"
    },
    {
      "type": "textarea",
      "id": "hero_subtitle",
      "label": "Hero subtitle",
      "default": "Classical Ayurvedic wisdom for herbs, digestion, immunity, skin, hair, stress, sleep, detox, and everyday wellness."
    },
    {
      "type": "header",
      "content": "Consultation CTA"
    },
    {
      "type": "text",
      "id": "consult_title",
      "label": "Consult title",
      "default": "Need help choosing the right Ayurvedic support?"
    },
    {
      "type": "textarea",
      "id": "consult_text",
      "label": "Consult description"
    },
    {
      "type": "text",
      "id": "consult_button",
      "label": "Consult button label",
      "default": "WhatsApp consults opening soon"
    },
    {
      "type": "url",
      "id": "consult_url",
      "label": "Consult button link"
    },
    {
      "type": "header",
      "content": "Disclaimer"
    },
    {
      "type": "textarea",
      "id": "default_disclaimer",
      "label": "Default health disclaimer",
      "default": "This content is for informational and educational purposes only. It is not intended as medical advice and should not replace consultation with a qualified healthcare professional."
    }
  ],
  "blocks": [
    {
      "type": "care_path",
      "name": "Care Path",
      "settings": [
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Digestion & gut"
        },
        {
          "type": "textarea",
          "id": "subtitle",
          "label": "Subtitle"
        },
        {
          "type": "text",
          "id": "tag",
          "label": "Blog tag filter",
          "info": "The Shopify blog tag to filter articles"
        },
        {
          "type": "text",
          "id": "cta_label",
          "label": "CTA label",
          "default": "Explore"
        }
      ]
    }
  ],
  "templates": ["blog", "index"]
}
{% endschema %}

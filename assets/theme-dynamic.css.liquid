:root {
  --theme-forest: #1f4d3d;
  --theme-forest-light: #2e5b4a;
  --theme-forest-soft: #5f5a54;
  --theme-forest-faint: rgba(31, 77, 61, 0.1);
  --theme-cream: #fdfcf8;
  --theme-cream-deep: #f6f2e8;
  --theme-sand: #f6f2e8;
  --theme-gold: #e29a12;
  --theme-copper: #8f4f36;
  --theme-rust: #8f4f36;
  --theme-red: #f44336;
  --theme-body-text: #5f5a54;
  --theme-heading-font: "Amstir", Georgia, serif;
  --theme-body-font: "Avenir", sans-serif;
  --font-serif: var(--theme-heading-font);
  --font-sans: var(--theme-body-font);
  --font-heading-family: "Amstir", Georgia, serif;
  --font-body-family: "Avenir", sans-serif;
  --brand-forest: #1f4d3d;
  --brand-gold: #e29a12;
  --brand-cream: #fdfcf8;
}
